	<queryString>
		<![CDATA[SELECT TEMP.BRANCH,B.NAME ,TEMP.PRODUCT ,H.DESCRIPTION,NVL(TEMP.BALANCE,0) BALANCE, NVL(TEMP.NOOFACC,0) NOOFACC FROM
    		 (SELECT T.BRANCH BRANCH,T.PRODUCT PRODUCT,SUM(BALANCE) BALANCE, COUNT(distinct(T.ACCOUNT_CODE)) NOOFACC FROM  (
     SELECT SUBSTR(A.ACCOUNT_CODE,1,4) BRANCH, SUBSTR(A.ACCOUNT_CODE,5,3) PRODUCT ,SUM(A.LEDGERBALANCE)  BALANCE, A.ACCOUNT_CODE
   FROM BALANCE.ACCOUNT A , ACCOUNT.ACCOUNT AA
     WHERE
    a.account_code = aa.account_code
  AND aa.dateaccountopen <= $P{as_on_date}
   AND (aa.dateaccountclose IS NULL or aa.dateaccountclose > $P{as_on_date})
 GROUP BY (SUBSTR(A.ACCOUNT_CODE,1,4) , SUBSTR(A.ACCOUNT_CODE,5,3), A.ACCOUNT_CODE )
    		 UNION ALL
 SELECT SUBSTR(T.ACCOUNT_CODE,1,4) BRANCH , SUBSTR(T.ACCOUNT_CODE,5,3) PRODUCT , SUM(DECODE(SUBSTR(t.TRANSACTIONINDICATOR_CODE,3,2),'DR', NVL(t.AMOUNT,0),-1*NVL(t.AMOUNT,0))) BALANCE , T.ACCOUNT_CODE
 FROM TRANSACTION.TRANSACTION_HT_VIEW T, ACCOUNT.ACCOUNT AA
    		 WHERE
  t.account_code = aa.account_code
 AND aa.dateaccountopen <= $P{as_on_date}
 AND (aa.dateaccountclose IS NULL or aa.dateaccountclose > $P{as_on_date})
 AND t.TXN_DATE>  $P{as_on_date}
 GROUP BY (SUBSTR(T.ACCOUNT_CODE,1,4) , SUBSTR(T.ACCOUNT_CODE,5,3), T.ACCOUNT_CODE )
    		 ) T
 GROUP BY T.BRANCH,T.PRODUCT ORDER BY 2) temp,HEADOFFICE.PRODUCT H, HEADOFFICE.BRANCH B
   WHERE TEMP.PRODUCT=H.PRODUCT_CODE
    AND TEMP.BRANCH=B.BRANCH_CODE]]>
	</queryString>
