	<queryString>
		<![CDATA[SELECT GROUP_CODE, CREDIT_AMOUNT, DEBIT_AMOUNT, DESCRIPTION
FROM (
    SELECT (CASE WHEN GRP = 'A' THEN 'ASSETS' ELSE ' ' END) AS GROUP_CODE,
           INITCAP(DES) AS DESCRIPTION,
           ABS(CR_AMT) AS CREDIT_AMOUNT,
           ABS(DR_AMT) AS DEBIT_AMOUNT
    FROM TEMP.MTEMP_TBGOAHEADER
    WHERE GRP = 'A'
      AND DR_AMT < 0
    ORDER BY SR_NO
)
UNION ALL
SELECT GROUP_CODE, CREDIT_AMOUNT, DEBIT_AMOUNT, DESCRIPTION
FROM (
    SELECT (CASE WHEN GRP = 'L' THEN 'LIABILITIES' ELSE ' ' END) AS GROUP_CODE,
           INITCAP(DES) AS DESCRIPTION,
           ABS(CR_AMT) AS CREDIT_AMOUNT,
           ABS(DR_AMT) AS DEBIT_AMOUNT
    FROM TEMP.MTEMP_TBGOAHEADER
    WHERE GRP = 'L'
      AND CR_AMT > 0
    ORDER BY SR_NO
)
UNION ALL
SELECT GROUP_CODE, CREDIT_AMOUNT, DEBIT_AMOUNT, DESCRIPTION
FROM (
    SELECT (CASE WHEN GRP IN ('I','E') THEN ' ' END) AS GROUP_CODE,
           INITCAP(DES) AS DESCRIPTION,
           ABS(CR_AMT) AS CREDIT_AMOUNT,
           ABS(DR_AMT) AS DEBIT_AMOUNT
    FROM TEMP.MTEMP_TBGOAHEADER
    WHERE GRP NOT IN ('A','L')
      AND (CR_AMT > 0 OR DR_AMT < 0)
    ORDER BY SR_NO
)]]>
	</queryString>
