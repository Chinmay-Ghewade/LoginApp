	<field name="GROSTOTALGMS" class="java.math.BigDecimal"/>
	<field name="GOLDRECIEPTNO" class="java.math.BigDecimal"/>
	<variable name="total_amt" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{TOTALVALUE}]]></variableExpression>
	</variable>
