	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["C:\\Users\\prajk\\eclipse-workspace\\LoginApp\\src\\main\\webapp\\Reports\\"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT rownum srno,L.ACCOUNT_CODE,S.SUBMISSIONDATE , S.WEIGHTTOTALGMS,S.RATEPER10GMS,S.TOTALVALUE,S.MARGINPERCENTAGE,
        S.RELEASEDATE,S.GOLDBAGNO,S.SECURITYVALUE,S.PARTICULAR,S.NOTE,
        S.CREATED_DATE,S.MODIFIED_DATE,S.GROSTOTALGMS,S.GOLDRECIEPTNO
        FROM ACCOUNT.ACCOUNTLOAN L,ACCOUNT.ACCOUNTSECURITYGOLDSILVER S,ACCOUNT.ACCOUNT A
        WHERE L.ACCOUNT_CODE= S.ACCOUNT_CODE
        and A.ACCOUNT_CODE= S.ACCOUNT_CODE
        AND SUBSTR(L.ACCOUNT_CODE,1,4)   =$P{branch_code}
        AND SUBSTR(L.ACCOUNT_CODE,5,3)   =$P{product_code}
        AND S.SUBMISSIONDATE BETWEEN
        TO_DATE($P{from_date},'DD-MON-YYYY')
        AND TO_DATE($P{to_date},'DD-MON-YYYY')
        AND S.SUBMISSIONDATE IS NOT NULL]]>
	</queryString>
	<field name="SRNO" class="java.math.BigDecimal"/>
	<field name="ACCOUNT_CODE" class="java.lang.String"/>
	<field name="SUBMISSIONDATE" class="java.sql.Timestamp"/>
	<field name="WEIGHTTOTALGMS" class="java.math.BigDecimal"/>
	<field name="RATEPER10GMS" class="java.math.BigDecimal"/>
