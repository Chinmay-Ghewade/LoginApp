	<queryString>
		<![CDATA[select rownum srno,BRANCH_CODE,ACCOUNT_CODE,NAME,MEMBER_NUMBER,CASTE_CODE,RELIGION_CODE,AC_SEXCODE,
       MALE_MEMBERS,FEMALE_MEMBERS,OTHER_MEMBERS,TOTAL_MEMBERS from (
select   MEMBER.BRANCH_CODE,
        MEMBER.ACCOUNT_CODE,
  MEMBER.NAME,
        MEMBER.MEMBER_NUMBER,
        MEMBER.CASTE_CODE,
        MEMBER.RELIGION_CODE,
        MEMBER.AC_SEXCODE,
        MEMBER.MALE_MEMBERS,
        MEMBER.FEMALE_MEMBERS,
        MEMBER.OTHER_MEMBERS,
        MEMBER.TOTAL_MEMBERS
 from bankdata.castwisememberlist MEMBER
 where MEMBER.branch_code= $P{branch_code}
 order by member.caste_code)]]>
	</queryString>
