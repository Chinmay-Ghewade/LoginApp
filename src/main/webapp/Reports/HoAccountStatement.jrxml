	<queryString>
		<![CDATA[SELECT ROWNUM SERIAL_NUMBER, HO_CODE, FN_GET_ACCOUNT_NAME(HO_CODE) ACCOUNT_NAME,
			 BAL_DATE, OPEN_BAL, DEBIT_BAL, CREDIT_BAL, BAL, DR_PRODUCT rec_product ,
       CR_PRODUCT pay_proudct, DR_INT_RATE rec_ir,
       CR_INT_RATE pay_ir, DR_INT_CALC rec_int, CR_INT_CALC pay_int
			 FROM bankdata.rep_ho_int
			 WHERE  BRANCH_CODE = $P{branch_code}
			 AND BAL_DATE between $P{as_on_date} AND $P{to_date}
			 AND HO_CODE BETWEEN $P{from_account} AND $P{to_account}
			 ORDER BY SERIAL_NUMBER, HO_CODE, BAL_DATE]]>
	</queryString>
	<field name="SERIAL_NUMBER" class="java.math.BigDecimal"/>
	<field name="HO_CODE" class="java.lang.String"/>
	<field name="ACCOUNT_NAME" class="java.lang.String"/>
	<field name="BAL_DATE" class="java.sql.Timestamp"/>
	<field name="OPEN_BAL" class="java.math.BigDecimal"/>
