	<queryString>
		<![CDATA[SELECT
    A.NAME AS NAME,
    B.DEPOSITAMOUNT AS DEPOSITAMOUNT,
    B.INTERESTRATE AS INTERESTRATE
FROM ACCOUNT.ACCOUNT A,
     ACCOUNT.ACCOUNTDEPOSIT B
WHERE A.ACCOUNT_CODE = $P{account_code}
AND A.ACCOUNT_CODE = B.ACCOUNT_CODE]]>
	</queryString>
	<field name="NAME" class="java.lang.String"/>
	<field name="DEPOSITAMOUNT" class="java.math.BigDecimal"/>
	<field name="INTERESTRATE" class="java.math.BigDecimal"/>
