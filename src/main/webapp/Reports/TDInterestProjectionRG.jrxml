	<queryString>
		<![CDATA[SELECT
    DATEDUE AS DATEDUE,
    INTERESTAMOUNT AS INTERESTAMOUNT,
    PERIODDAYS AS PERIODDAYS,
    APPLIEDFLAG AS APPLIEDFLAG,
    CREDITACCOUNT_CODE AS CREDITACCOUNT_CODE
FROM ACCOUNT.ACCOUNTDEPOSITDIARY
WHERE DEPOSITACCOUNT_CODE = $P{account_code}
ORDER BY DATEDUE]]>
	</queryString>
	<field name="DATEDUE" class="java.sql.Timestamp"/>
	<field name="INTERESTAMOUNT" class="java.math.BigDecimal"/>
	<field name="PERIODDAYS" class="java.math.BigDecimal"/>
	<field name="APPLIEDFLAG" class="java.lang.String"/>
	<field name="CREDITACCOUNT_CODE" class="java.lang.String"/>
	<variable name="INTEREST_AMT" class="java.math.BigDecimal" calculation="Sum">
