	<parameter name="user_id" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
    ACCOUNT_CODE,
    AC_NAME,
    LEDGER_BALANCE,
    LIMIT_AMOUNT,
    NULL AS PRINCIPAL_OVERDUE
FROM (
    SELECT
        R.ACCOUNT_CODE AS ACCOUNT_CODE,
        A.NAME AS AC_NAME,
        R.BALANCE AS LEDGER_BALANCE,
        NVL(AL.LIMITAMOUNT,0) AS LIMIT_AMOUNT,
        R.INTERESTRATE AS RATE_INT
    FROM TEMP.LOANCLASS R
         JOIN ACCOUNT.ACCOUNT A
            ON R.ACCOUNT_CODE = A.ACCOUNT_CODE
         LEFT JOIN ACCOUNT.ACCOUNTLOAN AL
            ON A.ACCOUNT_CODE = AL.ACCOUNT_CODE
    WHERE
        R.BRANCH_CODE BETWEEN $P{branch_code} AND $P{branch_code}
        AND R.BALANCE <> 0
    ORDER BY R.INTERESTRATE
)
ORDER BY RATE_INT]]>
	</queryString>
	<field name="ACCOUNT_CODE" class="java.lang.String"/>
	<field name="AC_NAME" class="java.lang.String"/>
	<field name="LEDGER_BALANCE" class="java.math.BigDecimal"/>
	<field name="LIMIT_AMOUNT" class="java.math.BigDecimal"/>
	<field name="PRINCIPAL_OVERDUE" class="java.lang.String"/>
	<variable name="BAL" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{LEDGER_BALANCE}]]></variableExpression>
	</variable>
	<variable name="AMOUNT" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{LIMIT_AMOUNT}]]></variableExpression>
	</variable>
	<variable name="PRI" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{PRINCIPAL_OVERDUE}]]></variableExpression>
	</variable>
