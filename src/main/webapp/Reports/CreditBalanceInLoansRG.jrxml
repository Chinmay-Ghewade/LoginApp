	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["./"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select BRCODE,FN_GET_BR_NAME(substr(BRCODE,1,4)) BRNAME,accountcode,name,sum(currbal+dr_cr) creditbalance from
	 (select substr(a.account_code,1,4) BRCODE,a.account_code accountcode ,a.name name ,b.LEDGERBALANCE currbal ,
	 ( select nvl(sum(decode(substr(t.transactionindicator_code,3,2),'DR',nvl(t.amount,0),-1*nvl(t.amount,0))),0)
	 from transaction.transaction_ht_view t
	 where t.account_code = a.account_code
	 and t.txn_Date > $P{as_on_date}
	 and t.transactionstatus='A') dr_cr from balance.account b,account.account a
	 where a.account_code=b.account_code and substr(a.account_code,5,1) in ('5','3')) temp
	 where temp.currbal+temp.dr_cr >0
	 group by (temp.BRCODE,temp.accountcode,temp.name)
	 order by temp.accountcode]]>
	</queryString>
	<field name="BRCODE" class="java.lang.String"/>
	<field name="BRNAME" class="java.lang.String"/>
	<field name="ACCOUNTCODE" class="java.lang.String"/>
	<field name="NAME" class="java.lang.String"/>
	<field name="CREDITBALANCE" class="java.math.BigDecimal"/>
	<variable name="GROUP_CREDITBALANCE_TOTAL" class="java.math.BigDecimal" resetType="Group" resetGroup="branchGroup" calculation="Sum">
