	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["./"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select  rownum sr_no ,customer_id,name,aadhar_card_no,kyc_cumplet,kyc_not_cumplet from (
				 select c.customer_id,c.name,c.aadhar_card_no,decode(c.aadhar_card_no,0,0,1) kyc_cumplet,decode(c.aadhar_card_no,0,1,0) kyc_not_cumplet
				 from customer.customer c where c.customer_id in (
				 select distinct(c.customer_id) from account.account a ,customer.customer c,balance.account  b
				 where  a.customer_id=c.customer_id and a.account_code=b.account_code and b.ledgerbalance <>0 and a.dateaccountopen <=$P{as_on_date}
				 and substr(a.account_code,5,3) not in (102,105,110,111,112,114,115,120,121,151)
				 and substr(c.customer_id,1,4)= $P{branch_code})  order by c.customer_id)]]>
	</queryString>
	<field name="SR_NO" class="java.math.BigDecimal"/>
	<field name="CUSTOMER_ID" class="java.lang.String"/>
	<field name="NAME" class="java.lang.String"/>
	<field name="AADHAR_CARD_NO" class="java.math.BigDecimal"/>
	<field name="KYC_CUMPLET" class="java.math.BigDecimal"/>
	<field name="KYC_NOT_CUMPLET" class="java.math.BigDecimal"/>
	<variable name="variable1" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{KYC_CUMPLET}]]></variableExpression>
	</variable>
	<variable name="variable2" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{KYC_NOT_CUMPLET}]]></variableExpression>
	</variable>
