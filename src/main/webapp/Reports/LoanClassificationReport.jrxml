		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
       ROWNUM AS SR_NO,
       AA.ACCOUNT_CODE AS ACCOUNT_NO,
       NVL(AA.NAME, 'A') AS NAME,
       AL.PERIODOFLOAN AS INT_RATE,
       AL.SANCTIONAMOUNT AS BALANCE_AMOUNT
FROM ACCOUNT.ACCOUNT AA,
     ACCOUNT.ACCOUNTLOAN AL
WHERE AA.ACCOUNT_CODE = AL.ACCOUNT_CODE
  AND SUBSTR(AA.ACCOUNT_CODE, 0, 4) BETWEEN $P{branch_code} AND $P{branch_code}
  AND (AA.DATEACCOUNTCLOSE IS NULL
       OR AA.DATEACCOUNTCLOSE > $P{as_on_date})
ORDER BY AA.ACCOUNT_CODE]]>
	</queryString>
	<field name="SR_NO" class="java.math.BigDecimal"/>
	<field name="ACCOUNT_NO" class="java.lang.String"/>
	<field name="NAME" class="java.lang.String"/>
	<field name="INT_RATE" class="java.math.BigDecimal"/>
	<field name="BALANCE_AMOUNT" class="java.math.BigDecimal"/>
	<variable name="AMOUNT" class="java.math.BigDecimal" resetType="Group" resetGroup="Amount" calculation="Sum">
		<variableExpression><![CDATA[$F{BALANCE_AMOUNT}]]></variableExpression>
	</variable>
