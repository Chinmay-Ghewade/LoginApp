		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT ROWNUM AS SR_NO,USER_ID,FIELD_NAME,ORIGINAL_VALUE,NEW_VALUE,MODIFICATION_TIME,OFFICER_ID,MODIFIEDUSER_ID FROM(
				 SELECT A.USER_ID,A.FIELD_NAME,A.ORIGINAL_VALUE,A.NEW_VALUE,
				 to_char(B.MODIFICATIONDATE_TIME,'DD/MM/YYYY HH.MM.SS') MODIFICATION_TIME ,B.OFFICER_ID,B.MODIFIEDUSER_ID
				 FROM AUDITTRAIL.USER_INFO_MODIFIACTIONDETAILS a,AUDITTRAIL.USER_INFO_MODIFIACTION b
				 where a.user_id=b.user_id and  to_date(to_char(b.MODIFICATIONDATE_TIME, 'dd-MM-yyyy'), 'dd-MM-yyyy') >= $P{from_date}
				 and to_date(to_char(b.MODIFICATIONDATE_TIME, 'dd-MM-yyyy'), 'dd-MM-yyyy') <=$P{to_date})]]>
	</queryString>
	<field name="SR_NO" class="java.math.BigDecimal"/>
	<field name="USER_ID" class="java.lang.String"/>
	<field name="FIELD_NAME" class="java.lang.String"/>
	<field name="ORIGINAL_VALUE" class="java.lang.String"/>
	<field name="NEW_VALUE" class="java.lang.String"/>
	<field name="MODIFICATION_TIME" class="java.lang.String"/>
	<field name="OFFICER_ID" class="java.lang.String"/>
	<field name="MODIFIEDUSER_ID" class="java.lang.String"/>
