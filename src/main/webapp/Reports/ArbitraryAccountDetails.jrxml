<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="ArbitraryAccountDetails.jrxml " language="groovy" pageWidth="1099" pageHeight="595" orientation="Landscape" columnWidth="1059" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="93063869-840c-45f0-b287-9c77cd7f4f4f">
