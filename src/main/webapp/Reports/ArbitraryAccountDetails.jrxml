	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="branch_code" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="as_on_date" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="to_date" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="report_title" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="user_id" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["./"]]></defaultValueExpression>
	</parameter>
	<parameter name="cashtype_from" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="cashtype_to" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
    SR_NO,
    account_code,
    NAME,
    open_bal,
    TOT_cr,
    TOT_dr,
    close_bal,
    total_int,
    CASE_TYPE,
    CASE_DESCRIPTION,
    DATEACCOUNTCLOSE
FROM (
    SELECT
        ROWNUM AS SR_NO,
        account_code,
        NAME,
        open_bal,
        TOT_cr,
        TOT_dr,
        close_bal,
        normal_int + penal_int AS total_int,
        CASE_TYPE,
        FN_GET_CASE_DESCRIPTION(CASE_TYPE) AS CASE_DESCRIPTION,
        DATEACCOUNTCLOSE
    FROM (
        SELECT
            account_code,
            NAME,
            SYSTEM.FN_GET_BALANCE_ASON(
                $P{as_on_date},
                account_code
            ) AS OPEN_BAL,

            SYSTEM.FN_GET_TOTAL_DR_CR(
                ACCOUNT_CODE,
               $P{as_on_date},
                $P{to_date},
                'CR',
                0
            ) AS TOT_CR,

            SYSTEM.FN_GET_TOTAL_DR_CR(
                ACCOUNT_CODE,
                $P{as_on_date},
                $P{to_date},
                'DR',
                0
            ) AS TOT_DR,

            SYSTEM.FN_GET_BALANCE_ASON(
                $P{to_date},
                account_code
            ) AS CLOSE_BAL,

            SYSTEM.FN_GET_LOAN_ADJ_AMT(
                ACCOUNT_CODE,
                $P{as_on_date},
                $P{to_date},
                'N'
            ) AS NORMAL_INT,

            SYSTEM.FN_GET_LOAN_ADJ_AMT(
                ACCOUNT_CODE,
               $P{as_on_date},
                $P{to_date},
                'P'
            ) AS PENAL_INT,

            SYSTEM.FN_GET_LOAN_CASE_STATUS(ACCOUNT_code) AS CASE_TYPE,
            DATEACCOUNTCLOSE

        FROM ACCOUNT.ACCOUNT
    )
    WHERE
        CASE_TYPE BETWEEN $P{cashtype_from} AND $P{cashtype_to}
        AND open_bal <> 0
    ORDER BY account_code
)
ORDER BY SR_NO]]>
	</queryString>
	<field name="SR_NO" class="java.math.BigDecimal"/>
	<field name="ACCOUNT_CODE" class="java.lang.String"/>
	<field name="NAME" class="java.lang.String"/>
	<field name="OPEN_BAL" class="java.math.BigDecimal"/>
	<field name="TOT_CR" class="java.math.BigDecimal"/>
	<field name="TOT_DR" class="java.math.BigDecimal"/>
	<field name="CLOSE_BAL" class="java.math.BigDecimal"/>
	<field name="TOTAL_INT" class="java.math.BigDecimal"/>
	<field name="CASE_TYPE" class="java.math.BigDecimal"/>
	<field name="CASE_DESCRIPTION" class="java.lang.String"/>
	<field name="DATEACCOUNTCLOSE" class="java.sql.Timestamp"/>
	<variable name="openbalance" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{OPEN_BAL}]]></variableExpression>
	</variable>
	<variable name="credit" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{TOT_CR}]]></variableExpression>
	</variable>
	<variable name="debit" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{TOT_DR}]]></variableExpression>
	</variable>
	<variable name="closebalance" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{CLOSE_BAL}]]></variableExpression>
	</variable>
	<variable name="totalinterst" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{TOTAL_INT}]]></variableExpression>
	</variable>
