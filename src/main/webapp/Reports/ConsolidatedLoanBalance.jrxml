	</parameter>
	<queryString>
		<![CDATA[select branch_code, name, goldloan, unsecuredloan, shorttermloan,
				  midtermloan, longtermloan, ibp, hccloan,
				  (goldloan+unsecuredloan+shorttermloan+midtermloan+longtermloan+ibp+hccloan) total
				  from ( SELECT b.BRANCH_CODE, b.name,
				   sum(case when pl.loantype='SGL' then abs(a.ledgerbalance) else 0.0 end) AS goldloan,
				   sum(case when pl.loantype='USL' then abs(a.ledgerbalance) else 0.0 end) AS unsecuredloan,
				   sum(case when pl.loantype='STL' then abs(a.ledgerbalance) else 0.0 end) AS shorttermloan,
				   sum(case when pl.loantype='MTL' then abs(a.ledgerbalance) else 0.0 end) AS midtermloan,
				   sum(case when pl.loantype='LTL' then abs(a.ledgerbalance) else 0.0 end) AS longtermloan,
				   sum(case when pl.loantype='IBP' then abs(a.ledgerbalance) else 0.0 end) AS ibp,
				   sum(case when pl.loantype='HCC' then abs(a.ledgerbalance) else 0.0 end) AS hccloan
				  from headoffice.branch b, balance.account a, headoffice.productparameterloan pl
				  WHERE substr(a.account_code,1,4)= b.branch_code
				   and substr(a.account_code,5,1) in ('5', '3')
				   and substr(a.account_code,5,3) =pl.product_code
				  group by b.branch_code, b.name
				  order by b.branch_code )
				 where branch_code between $P{branch_code} and $P{tobranch_code}]]>
	</queryString>
