	</parameter>
	<parameter name="user_id" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["./"]]></defaultValueExpression>
	</parameter>
	<parameter name="to_date" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="to_branchcode" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
    ROWNUM AS SERIAL,
    HOME_BRANCH,
    CUSTOMER_ID,
    NAME,
    TO_CHAR(CREATED_DATE, 'DD/MM/YYYY hh24.mi.ss') AS CREATED_D,
    USER_ID,
    OFFICER_ID,
    TO_CHAR(AS_ON_DATE, 'DD/MM/YYYY hh24.mi.ss') AS AS_ON_D
FROM
    CUSTOMER.CUSTOMER
WHERE
    TO_DATE(
       TO_CHAR(AS_ON_DATE, 'DD/MM/YYYY'),
       'dd/MM/yyyy'
    ) BETWEEN
        $P{as_on_date}
        AND $P{to_date}
    AND HOME_BRANCH BETWEEN
      $P{branch_code}
       AND $P{to_branchcode}
   AND STATUS = 'A'
ORDER BY
    SERIAL,
    HOME_BRANCH,
    CUSTOMER_ID,
    AS_ON_DATE]]>
	</queryString>
	<field name="SERIAL" class="java.math.BigDecimal"/>
	<field name="HOME_BRANCH" class="java.lang.String"/>
	<field name="CUSTOMER_ID" class="java.lang.String"/>
	<field name="NAME" class="java.lang.String"/>
	<field name="CREATED_D" class="java.lang.String"/>
	<field name="USER_ID" class="java.lang.String"/>
