	<property name="ireport.y" value="0"/>
	<parameter name="as_on_date" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="report_title" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="user_id" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="branch_code" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="to_date" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="from_product" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="to_product" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["./"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
    ROWNUM AS sr_no,
    account_code,
    name,
    open_d,
    balance,
    DATEACCOUNTCLOSE
FROM (
    SELECT
        a.account_code,
        a.name,
        TO_CHAR(a.dateaccountopen, 'dd/mm/yyyy') AS open_d,
        fn_get_balance_ason(
           $P{as_on_date},
            a.account_code
        ) AS balance,
        a.DATEACCOUNTCLOSE
    FROM
        account.account a
    WHERE
        SUBSTR(a.account_code, 5, 3) BETWEEN
            $P{from_product}
            AND $P{to_product}
)
WHERE
    balance < 0
    AND (
        DATEACCOUNTCLOSE IS NULL
        OR DATEACCOUNTCLOSE >= $P{to_date}
    )
ORDER BY
    sr_no]]>
	</queryString>
	<field name="SR_NO" class="java.math.BigDecimal"/>
	<field name="ACCOUNT_CODE" class="java.lang.String"/>
	<field name="NAME" class="java.lang.String"/>
	<field name="OPEN_D" class="java.lang.String"/>
	<field name="BALANCE" class="java.math.BigDecimal"/>
	<field name="DATEACCOUNTCLOSE" class="java.sql.Timestamp"/>
	<variable name="balance" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{BALANCE}]]></variableExpression>
	</variable>
