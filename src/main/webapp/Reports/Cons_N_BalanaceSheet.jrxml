	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["./"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT 0 as SR_NO, FN_GET_SHARE_AUTCAP_LMT($P{as_on_date}) AS LAST_YEAR_LIAB_INNER_AMT,   TO_NUMBER(0) LAST_YEAR_LIAB_OUTER_AMT, 'AUTHORISED SHARES CAPITAL' AS BOLD,
'' NORMAL, FN_GET_SHARE_AUTCAP_LMT($P{to_date}) LIAB_INNER_AMT,
TO_NUMBER(0) AS LIAB_OUTER_AMT,  TO_NUMBER(0) LAST_YEAR_ASSET_INNER_AMT,
 TO_NUMBER(0) LAST_YEAR_ASSET_OUTER_AMT, '' BOLD1, '' NORMAL1, TO_NUMBER(0) ASSET_INNER_AMT,
TO_NUMBER(0) ASSET_OUTER_AMT
FROM DUAL

UNION ALL

SELECT SR_NO, TO_NUMBER(ABS(LAST_YEAR_LIAB_INNER_AMT) ) AS LAST_YEAR_LIAB_INNER_AMT,
                 ABS(LAST_YEAR_LIAB_OUTER_AMT)AS LAST_YEAR_LIAB_OUTER_AMT,
                  DECODE(LIAB_BOLD_NORMAL,'B',LIAB_DESC,'') as BOLD  ,
	DECODE(LIAB_BOLD_NORMAL,'N',LIAB_DESC,'') as NORMAL,

                  TO_NUMBER( ABS(LIAB_INNER_AMT)) AS LIAB_INNER_AMT,
                   ABS(LIAB_OUTER_AMT) AS LIAB_OUTER_AMT,
                   TO_NUMBER(ABS(LAST_YEAR_ASSET_INNER_AMT)) AS LAST_YEAR_ASSET_INNER_AMT,
                   ABS(LAST_YEAR_ASSET_OUTER_AMT)AS LAST_YEAR_ASSET_OUTER_AMT,
                   DECODE(ASSET_BOLD_NORMAL,'B',ASSET_DESC,'')as BOLD1 ,DECODE(ASSET_BOLD_NORMAL,'N',ASSET_DESC,'') as NORMAL1,
                   TO_NUMBER(ABS(ASSET_INNER_AMT)) AS ASSET_INNER_AMT,
                   ABS(ASSET_OUTER_AMT) AS ASSET_OUTER_AMT
               FROM TEMP.CONS_TEMP_NBS_STRUCTURE
               ORDER BY SR_NO]]>
	</queryString>
	<field name="SR_NO" class="java.math.BigDecimal"/>
	<field name="LAST_YEAR_LIAB_INNER_AMT" class="java.math.BigDecimal"/>
	<field name="LAST_YEAR_LIAB_OUTER_AMT" class="java.math.BigDecimal"/>
	<field name="BOLD" class="java.lang.String"/>
	<field name="NORMAL" class="java.lang.String"/>
	<field name="LIAB_INNER_AMT" class="java.math.BigDecimal"/>
	<field name="LIAB_OUTER_AMT" class="java.math.BigDecimal"/>
	<field name="LAST_YEAR_ASSET_INNER_AMT" class="java.math.BigDecimal"/>
	<field name="LAST_YEAR_ASSET_OUTER_AMT" class="java.math.BigDecimal"/>
	<field name="BOLD1" class="java.lang.String"/>
	<field name="NORMAL1" class="java.lang.String"/>
	<field name="ASSET_INNER_AMT" class="java.math.BigDecimal"/>
	<field name="ASSET_OUTER_AMT" class="java.math.BigDecimal"/>
	<variable name="liab_tot" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{LIAB_OUTER_AMT}]]></variableExpression>
	</variable>
	<variable name="asset_tot" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{ASSET_OUTER_AMT}]]></variableExpression>
	</variable>
	<variable name="last_liab_tot" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{LAST_YEAR_LIAB_OUTER_AMT}]]></variableExpression>
	</variable>
	<variable name="last_asset_tot" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{LAST_YEAR_ASSET_OUTER_AMT}]]></variableExpression>
		<initialValueExpression><![CDATA[java.math.BigDecimal.ZERO]]></initialValueExpression>
	</variable>
