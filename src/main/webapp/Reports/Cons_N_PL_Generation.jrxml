<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="N_BalanaceSheet" language="groovy" pageWidth="1008" pageHeight="612" columnWidth="968" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="6948bbe2-552f-4f20-928d-7e85c7d8f0ae">
	<property name="ireport.zoom" value="1.5"/>
