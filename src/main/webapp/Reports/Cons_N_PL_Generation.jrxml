	<field name="NORMAL1" class="java.lang.String"/>
	<field name="INCOME_INNER_AMT" class="java.math.BigDecimal"/>
	<field name="INCOME_OUTER_AMT" class="java.math.BigDecimal"/>
	<variable name="liab_tot" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{EXPENSES_OUTER_AMT}]]></variableExpression>
	</variable>
	<variable name="asset_tot" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{INCOME_OUTER_AMT}]]></variableExpression>
	</variable>
	<variable name="last_liab_tot" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{LAST_YEAR_EXPENSES_OUTER_AMT}]]></variableExpression>
	</variable>
