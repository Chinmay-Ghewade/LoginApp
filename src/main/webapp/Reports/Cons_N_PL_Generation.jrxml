	<parameter name="to_date" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT
    SR_NO,

    ABS(LAST_EXPENSES_AMOUNT) AS LAST_YEAR_EXPENSES_INNER_AMT,
    ABS(LAST_EXPENSES_AMOUNT) AS LAST_YEAR_EXPENSES_OUTER_AMT,

    EXPENSES_DESC AS BOLD,
    '' AS NORMAL,

    ABS(EXPENSES_AMOUNT) AS EXPENSES_INNER_AMT,
    ABS(EXPENSES_AMOUNT) AS EXPENSES_OUTER_AMT,

    ABS(LAST_INCOME_AMOUNT) AS LAST_YEAR_INCOME_INNER_AMT,
    ABS(LAST_INCOME_AMOUNT) AS LAST_YEAR_INCOME_OUTER_AMT,

    INCOME_DESC AS BOLD1,
    '' AS NORMAL1,

    ABS(INCOME_AMOUNT) AS INCOME_INNER_AMT,
    ABS(INCOME_AMOUNT) AS INCOME_OUTER_AMT

FROM TEMP.CONS_TEMP_NPL_STRUCTURE
ORDER BY SR_NO]]>
	</queryString>
	<field name="SR_NO" class="java.math.BigDecimal"/>
	<field name="LAST_YEAR_EXPENSES_INNER_AMT" class="java.math.BigDecimal"/>
	<field name="LAST_YEAR_EXPENSES_OUTER_AMT" class="java.math.BigDecimal"/>
	<field name="BOLD" class="java.lang.String"/>
	<field name="NORMAL" class="java.lang.String"/>
