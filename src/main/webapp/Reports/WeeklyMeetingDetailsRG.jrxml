	<property name="ireport.zoom" value="1.5"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="as_on_date" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="branch_code" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="report_title" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="user_id" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["./"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT BRANCH_CODE,NAME,
			  NVL(Fn_Get_Gl_Bal(BRANCH_CODE,$P{as_on_date},9,'L03',1),0) + NVL( Fn_Get_Gl_Bal(BRANCH_CODE,$P{as_on_date},10,'L03',1),0) DEP,
			  NVL(Fn_Get_Gl_Bal(BRANCH_CODE,$P{as_on_date},9,'A05',1),0) + NVL(Fn_Get_Gl_Bal(BRANCH_CODE,$P{as_on_date},10,'A05',1),0) LOAN,
			  NVL(Fn_Get_Gl_Bal(BRANCH_CODE,$P{as_on_date},9,'A04',1),0) + NVL(Fn_Get_Gl_Bal(BRANCH_CODE,$P{as_on_date},10,'A04',1),0) INV,
			  NVL(Fn_Get_Gl_Bal(BRANCH_CODE,$P{as_on_date},9,'A02',1),0) + NVL(Fn_Get_Gl_Bal(BRANCH_CODE,$P{as_on_date},10,'A02',1),0) BANK,
			  NVL(Fn_Get_Gl_Bal(BRANCH_CODE,$P{as_on_date},9,'A01',1),0) + NVL(Fn_Get_Gl_Bal(BRANCH_CODE,$P{as_on_date},10,'A01',1),0) CASH
			  FROM HEADOFFICE.BRANCH where BRANCH_CODE<>'0000'
			  ORDER BY BRANCH_CODE]]>
	</queryString>
	<field name="BRANCH_CODE" class="java.lang.String"/>
	<field name="NAME" class="java.lang.String"/>
	<field name="DEP" class="java.math.BigDecimal"/>
	<field name="LOAN" class="java.math.BigDecimal"/>
	<field name="INV" class="java.math.BigDecimal"/>
	<field name="BANK" class="java.math.BigDecimal"/>
	<field name="CASH" class="java.math.BigDecimal"/>
	<variable name="TOTAL_DEP" class="java.math.BigDecimal" calculation="Sum">
