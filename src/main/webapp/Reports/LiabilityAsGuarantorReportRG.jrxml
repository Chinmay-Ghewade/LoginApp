	<parameter name="customer_id" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="select_type" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
    AG.CUSTOMER_ID AS CUSTOMER_ID_G,
    CG.NAME AS NAME_G,
    AA.ACCOUNT_CODE,
    CC.NAME AS NAME_A,
    AA.CUSTOMER_ID AS CUSTOMER_ID_A,
    TO_CHAR(AA.DATEACCOUNTOPEN, 'DD/MM/YYYY') AS OPEN_D,
    TO_CHAR(AA.DATEACCOUNTCLOSE, 'DD/MM/YYYY') AS CLOSE_D,
    AL.PERIODOFLOAN,
    TO_CHAR(AL.ACCOUNTREVIEWDATE, 'DD/MM/YYYY') AS REVIEW_D,
    AL.INSTALLMENTAMOUNT,
    AL.SANCTIONAMOUNT,
    ABS(BA.LEDGERBALANCE) AS BALANCE
FROM
    ACCOUNT.ACCOUNTGUARANTOR AG,
    ACCOUNT.ACCOUNT AA,
    CUSTOMER.CUSTOMER CC,
    CUSTOMER.CUSTOMER CG,
    ACCOUNT.ACCOUNTLOAN AL,
    BALANCE.ACCOUNT BA
WHERE
    AG.ACCOUNT_CODE = AA.ACCOUNT_CODE
    AND AL.ACCOUNT_CODE = AA.ACCOUNT_CODE
    AND AA.ACCOUNT_CODE = BA.ACCOUNT_CODE
    AND AA.CUSTOMER_ID = CC.CUSTOMER_ID
    AND AG.CUSTOMER_ID = CG.CUSTOMER_ID
AND (
    ($P{select_type} = 'A' AND AG.CUSTOMER_ID LIKE $P{branch_code%})
    OR
    ($P{select_type} = 'S' AND TRIM(AG.CUSTOMER_ID) = TRIM($P{customer_id}))
)
ORDER BY AG.CUSTOMER_ID, SERIAL_NUMBER]]>
	</queryString>
	<field name="CUSTOMER_ID_G" class="java.lang.String"/>
	<field name="NAME_G" class="java.lang.String"/>
	<field name="ACCOUNT_CODE" class="java.lang.String"/>
	<field name="NAME_A" class="java.lang.String"/>
	<field name="CUSTOMER_ID_A" class="java.lang.String"/>
	<field name="OPEN_D" class="java.lang.String"/>
	<field name="CLOSE_D" class="java.lang.String"/>
	<field name="PERIODOFLOAN" class="java.math.BigDecimal"/>
	<field name="REVIEW_D" class="java.lang.String"/>
	<field name="INSTALLMENTAMOUNT" class="java.math.BigDecimal"/>
	<field name="SANCTIONAMOUNT" class="java.math.BigDecimal"/>
	<field name="BALANCE" class="java.math.BigDecimal"/>
