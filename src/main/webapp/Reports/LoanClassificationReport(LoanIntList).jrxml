		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT ROW_NUMBER() OVER (PARTITION BY RATE_INT ORDER BY RATE_INT) AS ROWNO,
       ACCOUNT_CODE,
       AC_NAME,
       RATE_INT,
       TRAN_AMOUNT,
       PRODUCT,
       DESCRIPTION
FROM
(
    SELECT R.ACCOUNT_CODE,
           A.NAME AS AC_NAME,
           R.INTERESTRATE AS RATE_INT,
           R.BALANCE AS TRAN_AMOUNT,
           SUBSTR(A.ACCOUNT_CODE,5,3) AS PRODUCT,
           B.DESCRIPTION
    FROM TEMP.LOANCLASS R
         INNER JOIN ACCOUNT.ACCOUNT A
              ON R.ACCOUNT_CODE = A.ACCOUNT_CODE
         INNER JOIN HEADOFFICE.PRODUCT B
              ON SUBSTR(R.ACCOUNT_CODE,5,3) = B.PRODUCT_CODE
    WHERE R.BRANCH_CODE = $P{branch_code}
     -- AND R.BALANCE <> 0
)
ORDER BY RATE_INT]]>
	</queryString>
	<field name="ROWNO" class="java.math.BigDecimal"/>
	<field name="ACCOUNT_CODE" class="java.lang.String"/>
	<field name="AC_NAME" class="java.lang.String"/>
	<field name="RATE_INT" class="java.math.BigDecimal"/>
	<field name="TRAN_AMOUNT" class="java.math.BigDecimal"/>
	<field name="PRODUCT" class="java.lang.String"/>
	<field name="DESCRIPTION" class="java.lang.String"/>
	<variable name="Int Rate" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{RATE_INT}]]></variableExpression>
	</variable>
	<variable name="Amount" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{TRAN_AMOUNT}]]></variableExpression>
	</variable>
