	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["./"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
    ROWNUM AS SR,
    ACCOUNT_CODE,
    NAME,
    open_d,
    PANNO,
    TXN_NUMBER,
    txn_d,
    AMOUNT
FROM (
    SELECT
        ROWNUM AS SR,
        TXN_NUMBER,
        tx.ACCOUNT_CODE,
        c.PANNO,
        TO_CHAR(tx.TXN_DATE, 'dd/mm/yyyy') AS txn_d,
        tx.AMOUNT,
        INITCAP(A.NAME) AS NAME,
        TO_CHAR(a.dateaccountopen, 'dd/mm/yyyy') AS open_d
    FROM
        TRANSACTION.DAILYTXN tx
        JOIN ACCOUNT.ACCOUNT a
            ON tx.ACCOUNT_CODE = a.ACCOUNT_CODE
        JOIN CUSTOMER.CUSTOMER c
            ON a.customer_id = c.customer_id
    WHERE
        tx.TRANSACTIONINDICATOR_CODE = 'CSDR'
        AND tx.TXN_NUMBER > 0
        AND tx.AMOUNT > $P{amount}
        AND tx.BRANCH_CODE = $P{branch_code}
        AND a.dateaccountopen BETWEEN
            $P{as_on_date}
            AND $P{to_date}
        AND tx.TRANSACTIONSTATUS = 'A'
    ORDER BY
        tx.TXN_DATE,
        tx.ACCOUNT_CODE
)]]>
	</queryString>
	<field name="SR" class="java.math.BigDecimal"/>
	<field name="ACCOUNT_CODE" class="java.lang.String"/>
	<field name="NAME" class="java.lang.String"/>
	<field name="OPEN_D" class="java.lang.String"/>
	<field name="PANNO" class="java.lang.String"/>
	<field name="TXN_NUMBER" class="java.math.BigDecimal"/>
	<field name="TXN_D" class="java.lang.String"/>
	<field name="AMOUNT" class="java.math.BigDecimal"/>
	<variable name="amount" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{AMOUNT}]]></variableExpression>
	</variable>
