	<queryString>
		<![CDATA[select account_code,description,
       sum(op_balance) op_balance,
       sum(tot_debit) tot_debit,
       sum(tot_credit) tot_credit,
       sum(closingbalance) closingbalance
from history.cond_trial_balance
group by account_code,description
order by account_code]]>
	</queryString>
