	<queryString>
		<![CDATA[select ROWNUM AS SR_NO,BRANCH_CODE,scroll_date,scroll_number,subscroll_number,ACCOUNT_CODE,GLACCOUNT_CODE,
			FORACCOUNT_CODE,TRANSACTIONINDICATOR_CODE,AMOUNT,PARTICULAR,USER_ID,TRANSACTIONSTATUS,OFFICER_ID from(
select BRANCH_CODE, scroll_date, scroll_number,subscroll_number,ACCOUNT_CODE,GLACCOUNT_CODE,FORACCOUNT_CODE,
TRANSACTIONINDICATOR_CODE,AMOUNT,PARTICULAR,USER_ID,TRANSACTIONSTATUS,OFFICER_ID
from history.dailyscroll
where scroll_date>=$P{from_date} and scroll_date<= $P{to_date}
and transactionstatus='R' and BRANCH_CODE between $P{branch_code} and  $P{to_branch}
order by branch_code,scroll_date,scroll_number,subscroll_number)]]>
	</queryString>
