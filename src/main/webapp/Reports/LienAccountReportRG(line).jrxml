	</parameter>
	<queryString>
		<![CDATA[SELECT
    SUBSTR(TL_ACCOUNT_CODE, 5, 3) AS PRODUCT_CODE,
    TL_ACCOUNT_CODE,
    Fn_Get_Account_name(TL_ACCOUNT_CODE) AS tl_name,
    TO_CHAR(TL_OPEN_DATE, 'DD/MM/YYYY') AS TL_OPEN_D,
    TO_CHAR(TL_REVIEW_DATE, 'DD/MM/YYYY') AS TL_REVIEW_D,
    NVL(OS_BAL, 0) AS OS_BAL,
    LIEN_SR_NO,
    TL_IR,
    TD_ACCOUNT_CODE,
    Fn_Get_Account_name(TD_ACCOUNT_CODE) AS td_name,
    NVL(TD_AMOUNT, 0) AS TD_AMOUNT,
    TO_CHAR(TD_OPEN_DATE, 'DD/MM/YYYY') AS TD_OPEN_D,
    TO_CHAR(TD_MAT_DATE, 'DD/MM/YYYY') AS TD_MAT_D,
    NVL(TD_BAL, 0) AS TD_BAL,
    TD_IR
FROM
    BANKDATA.REPORT_LIEN_INFO
WHERE
    BRANCH_CODE = $P{branch_code}
    AND SUBSTR(TL_ACCOUNT_CODE, 5, 3) BETWEEN $P{from_product} AND $P{to_product}
    AND REP_DATE = $P{as_on_date}
ORDER BY   REP_SR]]>
	</queryString>
