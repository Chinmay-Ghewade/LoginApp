	<queryString>
		<![CDATA[SELECT FROMLIMIT || ' To ' || TOLIMIT AS LIMIT_AMOUNT,
       COUNT(ACCOUNT_CODE) AS NOOFACCOUNTS,
       SUM(BALANCE) AS BALANCE
FROM TEMP.LOANCLASS,
     TEMP.LIMITWISELOAN
WHERE BRANCH_CODE=$P{branch_code}
  AND LIMITAMOUNT BETWEEN FROMLIMIT AND TOLIMIT
GROUP BY FROMLIMIT, TOLIMIT
ORDER BY FROMLIMIT]]>
	</queryString>
	<field name="LIMIT_AMOUNT" class="java.lang.String"/>
	<field name="NOOFACCOUNTS" class="java.math.BigDecimal"/>
	<field name="BALANCE" class="java.math.BigDecimal"/>
	<variable name="No. Of Accounts" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{NOOFACCOUNTS}]]></variableExpression>
	</variable>
	<variable name="Outstanding Balance" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{BALANCE}]]></variableExpression>
	</variable>
