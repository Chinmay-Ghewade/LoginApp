	<parameter name="branch_code" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT A.ACCOUNT_CODE AS ACCOUNT_CODE, A.NAME AS NAME, A.DATEACCOUNTOPEN AS DATEACCOUNTOPEN,
                           AL.PERIODOFLOAN AS PERIODOFLOAN, AL.DIRECTOR_ID AS DIRECTOR_ID, AL.ACCOUNTREVIEWDATE AS ACCOUNTREVIEWDATE, AL.LIMITAMOUNT AS LIMITAMOUNT,
                           BA.LEDGERBALANCE AS LEDGERBALANCE,
                           D.NAME AS DIRECTOR_NAME
 FROM SHARES.DIRECTOR D, ACCOUNT.ACCOUNT A LEFT OUTER JOIN
                           (ACCOUNT.ACCOUNTLOAN AL left join BALANCE.ACCOUNT BA
   ON AL.ACCOUNT_CODE = BA.ACCOUNT_CODE)
   ON AL.ACCOUNT_CODE = A.ACCOUNT_CODE
 WHERE A.ACCOUNT_CODE LIKE $P{branch_code}
  AND D.DIRECTOR_ID > 0
  AND AL.DIRECTOR_ID > 0
  AND AL.DIRECTOR_ID = D.DIRECTOR_ID
 AND (A.DATEACCOUNTCLOSE IS NULL OR A.DATEACCOUNTCLOSE > $P{as_on_date})]]>
	</queryString>
	<field name="ACCOUNT_CODE" class="java.lang.String"/>
	<field name="NAME" class="java.lang.String"/>
	<field name="DATEACCOUNTOPEN" class="java.sql.Timestamp"/>
	<field name="PERIODOFLOAN" class="java.math.BigDecimal"/>
	<field name="DIRECTOR_ID" class="java.math.BigDecimal"/>
	<field name="ACCOUNTREVIEWDATE" class="java.sql.Timestamp"/>
	<field name="LIMITAMOUNT" class="java.math.BigDecimal"/>
	<field name="LEDGERBALANCE" class="java.math.BigDecimal"/>
	<field name="DIRECTOR_NAME" class="java.lang.String"/>
