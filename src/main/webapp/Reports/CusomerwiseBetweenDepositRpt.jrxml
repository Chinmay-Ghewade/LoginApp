	<queryString>
		<![CDATA[select  a.customer_id,a.name,a.account_code,to_char(a.dateaccountopen, 'DD/MM/YYYY') dateaccountopen, to_char(d.fromdate, 'DD/MM/YYYY') fromdate,
to_char(d.maturitydate, 'DD/MM/YYYY') maturitydate, d.depositamount,d.maturityvalue,fn_get_balance_ason($P{as_on_date},a.account_code)
balanceason
  from account.account a,account.accountdeposit d
  where  a.account_code=d.account_code and   a.customer_id in (
  select customer_id from (
  select a.customer_id,sum(fn_get_balance_ason($P{as_on_date},d.account_code))
led_balance from account.account a,account.accountdeposit d
  where a.account_code=d.account_code and (a.dateaccountclose is null
or a.dateaccountclose >$P{as_on_date})
  group by a.customer_id ) where led_balance between $P{limit_from} and $P{limit_to})  and
  fn_get_balance_ason($P{as_on_date},a.account_code) <>0 order by a.customer_id]]>
	</queryString>
