	<parameter name="as_on_date" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT rownum SrNo,BRANCH_NAME,PRODUCT_CODE,PRODUCT_NAME,
ACCOUNT_CODE,AC_NAME,NOMINEE_NAME,RELATION FROM (
SELECT fn_get_br_name(SUBSTR(N.ACCOUNT_CODE,1,4)) BRANCH_NAME,
SUBSTR(N.ACCOUNT_CODE,5,3) PRODUCT_CODE,
fn_get_product_name(SUBSTR(N.ACCOUNT_CODE,5,3)) PRODUCT_NAME,
TO_NUMBER(SUBSTR(N.ACCOUNT_CODE,8,7)) ACCOUNT_CODE,
INITCAP(N.NAME) AC_NAME,
INITCAP(N.NOMINEE_NAME) NOMINEE_NAME,
INITCAP(N.RELATION_NAME) RELATION
 FROM BANKDATA.ACCOUNTNOMINEE_LIST N
where SUBSTR(N.ACCOUNT_CODE,1,4)=$P{branch_code}
AND SUBSTR(N.ACCOUNT_CODE,5,3)=$P{product_code}
ORDER BY N.ACCOUNT_CODE)]]>
	</queryString>
	<field name="SRNO" class="java.math.BigDecimal"/>
	<field name="BRANCH_NAME" class="java.lang.String"/>
	<field name="PRODUCT_CODE" class="java.lang.String"/>
	<field name="PRODUCT_NAME" class="java.lang.String"/>
	<field name="ACCOUNT_CODE" class="java.math.BigDecimal"/>
	<field name="AC_NAME" class="java.lang.String"/>
	<field name="NOMINEE_NAME" class="java.lang.String"/>
	<field name="RELATION" class="java.lang.String"/>
