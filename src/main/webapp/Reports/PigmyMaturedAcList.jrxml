	<queryString>
		<![CDATA[SELECT ROWNUM AS serial,
       account_no,
       NAME, open_d, maturityd,
      ('Agent Name: ' || agent_id || '  ' || agent_name) AGENT,
      openingbalance, product_code, description

FROM (SELECT p.account_code AS account_no, TRIM (a.NAME) AS NAME,
      TO_CHAR (p.fromdate, 'dd/mm/yyyy') AS open_d,
      TO_CHAR (p.maturitydate, 'dd/mm/yyyy') AS maturityd,
      p.agent_id AS agent_id, openingbalance, ag.NAME agent_name,
      p.description, SUBSTR (p.account_code, 5, 3) product_code

FROM ACCOUNT.accountpigmy p,
     ACCOUNT.ACCOUNT a,
     balance.ACCOUNT b,
     branch.AGENT ag,
     headoffice.product p

WHERE p.account_code = a.account_code
      AND p.agent_id = ag.agent_id
      AND SUBSTR (p.account_code, 5, 3) = p.product_code
      AND P.account_code = b.account_code
      AND b.ledgerbalance <> 0
      AND ag.branch_code = SUBSTR (p.account_code, 0, 4)
      AND p.maturitydate >= $P{as_on_date}
      AND p.maturitydate <= $P{to_date}
      AND SUBSTR (p.account_code, 0, 4) = $P{branch_code}

ORDER BY p.agent_id)]]>
	</queryString>
