	<queryString>
		<![CDATA[select ROWNUM as sr_no,ACCOUNT_CODE,name,Drawingpower,txn_d,ledbal from(
 select ACCOUNT_CODE,name,Drawingpower,txn_d, ledbal from (
 SELECT A.ACCOUNT_CODE,a.name,L.Drawingpower,to_char(t.txn_date,'dd/mm/yyyy')txn_d,
 fn_get_balance_ason(t.txn_date,t.account_code) ledbal
 FROM ACCOUNT.ACCOUNT A,ACCOUNT.ACCOUNTLOAN L,transaction.dailytxn t
 WHERE A.ACCOUNT_CODE=L.ACCOUNT_CODE and a.account_code=t.account_code
 AND (a.dateaccountclose is null or a.dateaccountclose >=$P{as_on_date}))
 where abs(ledbal) > Drawingpower and substr(account_code,5,3)
 BETWEEN $P{from_product} AND $P{to_product})order by sr_no]]>
	</queryString>
	<field name="SR_NO" class="java.math.BigDecimal"/>
	<field name="ACCOUNT_CODE" class="java.lang.String"/>
	<field name="NAME" class="java.lang.String"/>
	<field name="DRAWINGPOWER" class="java.math.BigDecimal"/>
