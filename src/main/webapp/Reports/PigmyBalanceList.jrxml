	<queryString>
		<![CDATA[SELECT ROWNUM AS SERIAL, ACCOUNT_CODE, NAME, BALANCE, AGENT_NAME FROM(
 SELECT A.ACCOUNT_CODE,A.NAME,fn_get_balance_ason(TO_DATE($P{as_on_date},'DD/MM/YYYY'),A.ACCOUNT_CODE)BALANCE, AG.NAME AS AGENT_NAME
 FROM ACCOUNT.ACCOUNT A, ACCOUNT.ACCOUNTPIGMY P, BRANCH.AGENT AG
 WHERE A.ACCOUNT_CODE=P.ACCOUNT_CODE
 AND SUBSTR(A.ACCOUNT_CODE,1,4)= $P{branch_code}
 AND P.AGENT_ID= $P{agentCode}
 AND P.AGENT_ID=AG.AGENT_ID
 AND AG.BRANCH_CODE=$P{branch_code}
 AND ( A.DATEACCOUNTOPEN  IS NULL OR A.DATEACCOUNTOPEN <= CDATE($P{as_on_date}))
 AND ( A.DATEACCOUNTCLOSE IS NULL OR A.DATEACCOUNTCLOSE > CDATE($P{as_on_date}))
 AND fn_get_balance_ason(TO_DATE($P{as_on_date},'DD/MM/YYYY'),A.ACCOUNT_CODE)<>0
ORDER BY a.account_code )]]>
	</queryString>
	<field name="SERIAL" class="java.math.BigDecimal"/>
	<field name="ACCOUNT_CODE" class="java.lang.String"/>
	<field name="NAME" class="java.lang.String"/>
	<field name="BALANCE" class="java.math.BigDecimal"/>
	<field name="AGENT_NAME" class="java.lang.String"/>
