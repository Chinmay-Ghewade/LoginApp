<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="AdvancesAndDepositsRG" language="groovy" pageWidth="696" pageHeight="842" columnWidth="656" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="987ff58a-1549-4c59-be2e-66c606dfc5f5">
	<property name="ireport.zoom" value="1.5"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="as_on_date" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="branch_code" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="report_title" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="user_id" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["./"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT    H.BRANCH_CODE  AS BRCODE  ,b.name AS BRNAME ,
	SUM(DECODE(A.CODETYPE,'DD',H.OPENINGBALANCE+(H.CREDITCASH+H.CREDITTRANSFER+H.CREDITCLEARING)- (H.DEBITCASH+H.DEBITTRANSFER+H.DEBITCLEARING),0)) as DEPOSITS,
	ABS(SUM(DECODE(A.CODETYPE,'LL',H.OPENINGBALANCE+(H.CREDITCASH+H.CREDITTRANSFER+H.CREDITCLEARING)- (H.DEBITCASH+H.DEBITTRANSFER+H.DEBITCLEARING),0))) as ADVANCES
	FROM  BALANCE.BRANCHGLHISTORY H,HEADOFFICE.GLACCOUNT A,headoffice.BRANCH b
	WHERE   H.GLACCOUNT_CODE=A.GLACCOUNT_CODE
	AND H.TXN_DATE=  $P{as_on_date}
	AND A.CODETYPE IN ('LL','DD')
	and h.branch_code=b.branch_code
	GROUP BY ( H.BRANCH_CODE ,b.name)
	ORDER BY H.BRANCH_CODE]]>
	</queryString>
	<field name="BRCODE" class="java.lang.String"/>
	<field name="BRNAME" class="java.lang.String"/>
	<field name="DEPOSITS" class="java.math.BigDecimal"/>
	<field name="ADVANCES" class="java.math.BigDecimal"/>
	<variable name="TOTAL_DEPOSITS" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{DEPOSITS}]]></variableExpression>
	</variable>
	<variable name="TOTAL_ADVANCES" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{ADVANCES}]]></variableExpression>
	</variable>
