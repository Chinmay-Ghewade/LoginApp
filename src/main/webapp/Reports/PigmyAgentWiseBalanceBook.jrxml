<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="PigmyAgentWiseBalanceBook" pageWidth="831" pageHeight="595" orientation="Landscape" columnWidth="791" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="e3b6e8c2-2ef0-4c34-92b5-fca3c3f82b11">
	<property name="ireport.zoom" value="2.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="branch_code" class="java.lang.String"/>
	<parameter name="starting_date" class="java.lang.String"/>
	<parameter name="ending_date" class="java.lang.String"/>
	<parameter name="from_agent_code" class="java.lang.String"/>
	<parameter name="to_agent_code" class="java.lang.String"/>
	<parameter name="report_title" class="java.lang.String"/>
	<parameter name="as_on_date" class="java.lang.String"/>
	<parameter name="user_id" class="java.lang.String"/>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["./"]]></defaultValueExpression>
	</parameter>
	<parameter name="branch_code%" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT rownum serial_no, AGENT_CODE,AGENT_NAME,AC_CODE,AC_NAME,OP_BAL,TOT_DR,TOT_CR,CL_BAL
		 FROM (
		 SELECT AGENT_CODE, AC_CODE, AC_NAME,
		 FN_GET_BALANCE_ASON(TO_DATE($P{starting_date})-1, AC_CODE ) OP_BAL,
		 Fn_Get_ACCOUNT_DR_CR (AC_CODE,$P{starting_date},$P{ending_date},'D') TOT_DR,
		 Fn_Get_ACCOUNT_DR_CR (AC_CODE,$P{starting_date},$P{ending_date},'C') TOT_CR,
		 FN_GET_BALANCE_ASON($P{ending_date}, AC_CODE ) CL_BAL,
		 FN_GET_AGENT_NAME (SUBSTR(AC_CODE,1,4), AGENT_CODE) AGENT_NAME
		 FROM (
		 SELECT ACCOUNT_CODE AC_CODE ,
		 NAME AC_NAME,
		 FN_GET_PGAC_AGENT(ACCOUNT_CODE, TO_DATE($P{starting_date})-1) AGENT_CODE
		 FROM ACCOUNT.ACCOUNT WHERE  ACCOUNT_CODE LIKE $P{branch_code%})
		 WHERE AGENT_CODE between $P{from_agent_code}  and  $P{to_agent_code}
		 order by AGENT_CODE,AC_CODE)
		 WHERE (ABS(OP_BAL)+ABS(TOT_DR)+ABS(TOT_CR)+ABS(CL_BAL))>0]]>
	</queryString>
	<field name="SERIAL_NO" class="java.math.BigDecimal"/>
	<field name="AGENT_CODE" class="java.math.BigDecimal"/>
	<field name="AGENT_NAME" class="java.lang.String"/>
	<field name="AC_CODE" class="java.lang.String"/>
	<field name="AC_NAME" class="java.lang.String"/>
	<field name="OP_BAL" class="java.math.BigDecimal"/>
	<field name="TOT_DR" class="java.math.BigDecimal"/>
	<field name="TOT_CR" class="java.math.BigDecimal"/>
	<field name="CL_BAL" class="java.math.BigDecimal"/>
	<variable name="OPEN_TOTAL" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{OP_BAL}]]></variableExpression>
	</variable>
	<variable name="DR_TOTAL" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{TOT_DR}]]></variableExpression>
	</variable>
	<variable name="CR_TOTAL" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{TOT_CR}]]></variableExpression>
	</variable>
	<variable name="CL_TOTAL" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{CL_BAL}]]></variableExpression>
	</variable>
