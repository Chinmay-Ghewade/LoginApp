	<queryString>
		<![CDATA[SELECT I.ACCOUNT_CODE,
       A.NAME, S.DESCRIPTION AS LOAN_TYPE,
       I.POLICYNUMBER,
       TO_CHAR(I.START_DATE,'DD/MM/YYYY') AS POLICY_D,
       TO_CHAR(I.END_DATE, 'DD/MM/YYYY') AS POLICY_ED,
       I.INSURANCENAME, C.PHONEMOBILE, I.PARTICULAR

FROM ACCOUNT.ACCOUNT A,
     ACCOUNT.ACCOUNTSECURITYINSURANCE I ,
     GLOBALCONFIG.SECURITYTYPE S,
     CUSTOMER.CUSTOMER C

WHERE I.ACCOUNT_CODE = A.ACCOUNT_CODE
      AND S.SECURITYTYPE_CODE = I.SECURITYTYPE_CODE
      AND A.CUSTOMER_ID = C.CUSTOMER_ID
      AND SUBSTR(I.ACCOUNT_CODE, 0,4) LIKE $P{branch_code%}
      AND I.START_DATE BETWEEN  $P{as_on_date}
      AND $P{to_date}]]>
	</queryString>
	<field name="ACCOUNT_CODE" class="java.lang.String"/>
	<field name="NAME" class="java.lang.String"/>
	<field name="LOAN_TYPE" class="java.lang.String"/>
	<field name="POLICYNUMBER" class="java.lang.String"/>
	<field name="POLICY_D" class="java.lang.String"/>
