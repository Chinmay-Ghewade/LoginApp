	</parameter>
	<queryString>
		<![CDATA[SELECT
    A.ACCOUNT_CODE,
    A.NAME,
    A.CUSTOMER_ID,
    B.LEDGERBALANCE,
    A.RISKCATEGORY

FROM ACCOUNT.ACCOUNT A,
     BALANCE.ACCOUNT B

WHERE A.ACCOUNT_CODE = B.ACCOUNT_CODE
AND A.DATEACCOUNTCLOSE IS NULL

AND
(
    '$P!{single_all}' = 'A'
    OR
    SUBSTR(A.ACCOUNT_CODE,5,3) = '$P!{product_code}'
)

AND A.RISKCATEGORY = '$P!{risk_category}']]>
	</queryString>
	<field name="ACCOUNT_CODE" class="java.lang.String"/>
	<field name="NAME" class="java.lang.String"/>
	<field name="CUSTOMER_ID" class="java.lang.String"/>
	<field name="LEDGERBALANCE" class="java.math.BigDecimal"/>
	<field name="RISKCATEGORY" class="java.lang.String"/>
	<variable name="Balance" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{LEDGERBALANCE}]]></variableExpression>
	</variable>
