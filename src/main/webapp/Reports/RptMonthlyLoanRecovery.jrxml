	<field name="CASH_PRINCIPAL" class="java.math.BigDecimal"/>
	<field name="TRAN_PRINCIPAL" class="java.math.BigDecimal"/>
	<field name="CASH_INTEREST" class="java.math.BigDecimal"/>
	<field name="TRAN_INTEREST" class="java.math.BigDecimal"/>
	<variable name="Sr.No" class="java.lang.Number" resetType="Group" resetGroup="PRODUCT_TYPE" calculation="DistinctCount">
		<variableExpression><![CDATA[$F{ACCOUNT_CODE}]]></variableExpression>
	</variable>
	<variable name="CASH_TOTAL" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{CASH_PRINCIPAL}]]></variableExpression>
	</variable>
	<variable name="Total_Amt" class="java.math.BigDecimal">
		<variableExpression><![CDATA[$F{CASH_PRINCIPAL} + $F{TRAN_PRINCIPAL} + $F{CASH_INTEREST} + $F{TRAN_INTEREST}]]></variableExpression>
	</variable>
	<variable name="prtotalbal" class="java.math.BigDecimal" resetType="Group" resetGroup="PRODUCT_TYPE" calculation="Sum">
