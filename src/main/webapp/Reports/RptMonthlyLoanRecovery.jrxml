	<queryString>
		<![CDATA[SELECT SUBSTR(R.ACCOUNT_CODE,5,3)SCHEM_NO,TO_NUMBER(SUBSTR(R.ACCOUNT_CODE,8,7)) ACCOUNT_CODE,
initcap(A.NAME)name,
fn_get_product_name(SUBSTR(R.ACCOUNT_CODE,5,3)) scheme_name,
fn_get_balance_ason($P{as_on_date},A.account_code) AS_ON_BALANCE,
nvl(R.CASH_PRINCIPAL,0) as CASH_PRINCIPAL,nvl(R.TRAN_PRINCIPAL,0) as TRAN_PRINCIPAL,nvl(R.CASH_INTEREST,0) as CASH_INTEREST,nvl(R.TRAN_INTEREST,0) as TRAN_INTEREST
FROM ACCOUNT.ACCOUNT A,BANKDATA.LOANMONTHLYRECOVERY R
WHERE A.ACCOUNT_CODE=R.ACCOUNT_CODE
and (NVL(R.CASH_PRINCIPAL,0)<>0
OR NVL(R.TRAN_PRINCIPAL,0)<>0
OR NVL(R.CASH_INTEREST,0)<>0
OR NVL(R.TRAN_INTEREST,0)<>0)
order by r.account_code]]>
	</queryString>
	<field name="SCHEM_NO" class="java.lang.String"/>
	<field name="ACCOUNT_CODE" class="java.math.BigDecimal"/>
	<field name="NAME" class="java.lang.String"/>
