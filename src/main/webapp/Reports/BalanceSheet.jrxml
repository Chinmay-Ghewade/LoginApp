	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["./"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT SR_NO, DECODE(LIAB_BOLD_NORMAL,'B',LIAB_DESC,'') as BOLD,DECODE(LIAB_BOLD_NORMAL,'N',LIAB_DESC,'') as NORMAL, TO_NUMBER(DECODE(LIAB_INNER_AMT,0,'',ABS(LIAB_INNER_AMT))) AS LIAB_INNER_AMT,
  TO_NUMBER(DECODE(LIAB_OUTER_AMT,0,'',ABS(LIAB_OUTER_AMT)))
 AS LIAB_OUTER_AMT,DECODE(ASSET_BOLD_NORMAL,'B',ASSET_DESC,'')as BOLD1 ,DECODE(ASSET_BOLD_NORMAL,'N',ASSET_DESC,'')as NORMAL1, TO_NUMBER(DECODE(ASSET_INNER_AMT,0,'',ABS(ASSET_INNER_AMT)))
 AS ASSET_INNER_AMT, TO_NUMBER(DECODE(ASSET_OUTER_AMT,0,'',ABS(ASSET_OUTER_AMT)))
 AS ASSET_OUTER_AMT
              FROM TEMP.TEMP_BS_STRUCTURE t
            WHERE t.BRANCH_CODE= $P{branch_code}

 order by sr_no]]>
	</queryString>
	<field name="SR_NO" class="java.math.BigDecimal"/>
	<field name="BOLD" class="java.lang.String"/>
	<field name="NORMAL" class="java.lang.String"/>
	<field name="LIAB_INNER_AMT" class="java.math.BigDecimal"/>
	<field name="LIAB_OUTER_AMT" class="java.math.BigDecimal"/>
	<field name="BOLD1" class="java.lang.String"/>
	<field name="NORMAL1" class="java.lang.String"/>
	<field name="ASSET_INNER_AMT" class="java.math.BigDecimal"/>
	<field name="ASSET_OUTER_AMT" class="java.math.BigDecimal"/>
	<variable name="sumAssetOuterAmt" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[($F{SR_NO}==0)?0:$F{ASSET_OUTER_AMT}]]></variableExpression>
		<initialValueExpression><![CDATA[]]></initialValueExpression>
	</variable>
	<variable name="sumLibOuterAmt" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[($F{SR_NO}==0)?0:$F{LIAB_OUTER_AMT}]]></variableExpression>
		<initialValueExpression><![CDATA[]]></initialValueExpression>
	</variable>
