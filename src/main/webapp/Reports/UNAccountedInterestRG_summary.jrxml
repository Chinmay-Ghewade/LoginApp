	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["./"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT ROWNUM AS SR_NO, ACCOUNT_CODE,
              INITCAP(NAME) AS NAME,
              UNACCOUNTED_INTEREST
FROM (
SELECT B.ACCOUNT_CODE, B.NAME,
       A.UNACCOUNTED_INTEREST

FROM HISTORY.TLCCOVERDUEADVANCE A
     JOIN ACCOUNT.ACCOUNT B ON  B.ACCOUNT_CODE = A.ACCOUNT_CODE

WHERE A.UNACCOUNTED_INTEREST >0
      AND SUBSTR(A.ACCOUNT_CODE,1,7)>= $P{branchcode_productcode}
      AND SUBSTR(A.ACCOUNT_CODE,1,7)<= $P{branchcode_productcode1}
      AND A.OVD_ADV_DATE = $P{as_on_date}
ORDER BY ACCOUNT_CODE
)]]>
	</queryString>
	<field name="SR_NO" class="java.math.BigDecimal"/>
	<field name="ACCOUNT_CODE" class="java.lang.String"/>
	<field name="NAME" class="java.lang.String"/>
	<field name="UNACCOUNTED_INTEREST" class="java.math.BigDecimal"/>
	<variable name="AMOUNT" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{UNACCOUNTED_INTEREST}]]></variableExpression>
	</variable>
