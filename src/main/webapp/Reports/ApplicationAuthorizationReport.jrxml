	<queryString>
		<![CDATA[SELECT ROWNUM AS SR_NO,APPLICATIOND,APPLICATION_NUMBER,ACCOUNT_CODE,
				 NAME,BRANCH_CODE,PRODUCT_TYPE,USER_ID,CREATED_D,OFFICER_ID,AUTHORIZE_D from( SELECT					 TO_CHAR(AP.APPLICATIONDATE,'DD/MM/YYYY')APPLICATIOND,				 AP.APPLICATION_NUMBER,					 A.ACCOUNT_CODE,A.NAME,
 AP.BRANCH_CODE,
 FN_GET_PRODUCT_TYPE(AP.PRODUCT_CODE)PRODUCT_TYPE,
 A.USER_ID,TO_CHAR(AP.CREATED_DATE,'DD/MM/YYYY HH24.MI.SS')CREATED_D, A.OFFICER_ID,
 TO_CHAR(A.CREATED_DATE,'DD/MM/YYYY HH24.MI.SS')AUTHORIZE_D
FROM APPLICATION.APPLICATION AP,ACCOUNT.ACCOUNT A
 WHERE AP.APPLICATION_NUMBER = A.APPLICATION_NUMBER
 AND AP.APPLICATIONDATE BETWEEN $P{from_date} AND $P{to_date}
 AND AP.STATUS = 'A' AND AP.BRANCH_CODE BETWEEN $P{branch_code} AND $P{tobranch_code}
 AND AP.PRODUCT_CODE BETWEEN $P{from_product} AND $P{to_product}
 ORDER BY TO_CHAR(AP.APPLICATIONDATE,'DD/MM/YYYY'),a.ACCOUNT_CODE
)ORDER BY SR_NO]]>
	</queryString>
	<field name="SR_NO" class="java.math.BigDecimal"/>
	<field name="APPLICATIOND" class="java.lang.String"/>
	<field name="APPLICATION_NUMBER" class="java.lang.String"/>
	<field name="ACCOUNT_CODE" class="java.lang.String"/>
