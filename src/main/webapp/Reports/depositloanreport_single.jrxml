<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="depositloanreport_single" language="groovy" pageWidth="1080" pageHeight="864" columnWidth="1040" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="fd917158-497b-4a0d-936e-0953f13298b4">
	<property name="ireport.zoom" value="1.5"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="branch_code" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="product_code" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="as_on_date" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="to_date" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="report_title" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="user_id" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["./"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT ROWNUM SR_NO, ACCOUNT_CODE, PRODUCT_CODE, AC_NAME, TDACCOUNT_CODE,
DATEACCOUNTOPEN, ACCOUNTREVIEWDATE, DEPOSITAMOUNT, SANCTIONAMOUNT,
'' return_date,'' officer_sign,'' customer_sign,'' details,
FN_GET_PRODUCT_NAME (SUBSTR (ACCOUNT_CODE, 5, 3)) PRODUCT_NAME

FROM (SELECT   ACCOUNT_CODE, PRODUCT_CODE, AC_NAME, TDACCOUNT_CODE, DATEACCOUNTOPEN,
      ACCOUNTREVIEWDATE,DEPOSITAMOUNT,SANCTIONAMOUNT

FROM (SELECT A.ACCOUNT_CODE ACCOUNT_CODE,
      SUBSTR (A.ACCOUNT_CODE, 5, 3) PRODUCT_CODE,
      A.NAME AC_NAME, H.TDACCOUNT_CODE TDACCOUNT_CODE,
      A.DATEACCOUNTOPEN DATEACCOUNTOPEN, L.ACCOUNTREVIEWDATE ACCOUNTREVIEWDATE,
      D.DEPOSITAMOUNT DEPOSITAMOUNT, L.SANCTIONAMOUNT SANCTIONAMOUNT

FROM ACCOUNT.ACCOUNT A,
     HISTORY.LIENHISTORY H,
     ACCOUNT.ACCOUNTLOAN L,
     ACCOUNT.ACCOUNTDEPOSIT D

WHERE A.ACCOUNT_CODE = L.ACCOUNT_CODE
      AND H.TLACCOUNT_CODE = L.ACCOUNT_CODE
      AND H.TDACCOUNT_CODE = D.ACCOUNT_CODE
      AND A.DATEACCOUNTOPEN BETWEEN $P{as_on_date} AND $P{to_date}
      AND SUBSTR (L.ACCOUNT_CODE, 1, 4) = $P{branch_code}
      AND SUBSTR (L.ACCOUNT_CODE, 5, 3) = $P{product_code}
UNION ALL
SELECT A.ACCOUNT_CODE ACCOUNT_CODE, SUBSTR (A.ACCOUNT_CODE, 5, 3) PRODUCT_CODE,
       A.NAME AC_NAME,
       H.TDACCOUNT_CODE TDACCOUNT_CODE,A.DATEACCOUNTOPEN DATEACCOUNTOPEN,
       L.ACCOUNTREVIEWDATE ACCOUNTREVIEWDATE,
       FN_GET_BALANCE_ASON(TO_DATE ($P{to_date}, 'DD/MM/YYYY'), P.ACCOUNT_CODE)
       DEPOSITAMOUNT,L.SANCTIONAMOUNT SANCTIONAMOUNT

FROM ACCOUNT.ACCOUNT A,
     HISTORY.LIENHISTORY H,
     ACCOUNT.ACCOUNTLOAN L,
     ACCOUNT.ACCOUNTPIGMY P

WHERE A.ACCOUNT_CODE = L.ACCOUNT_CODE
    AND H.TLACCOUNT_CODE = L.ACCOUNT_CODE
    AND H.TDACCOUNT_CODE = P.ACCOUNT_CODE
    AND A.DATEACCOUNTOPEN BETWEEN $P{as_on_date} AND $P{to_date}
AND SUBSTR (L.ACCOUNT_CODE, 1, 4) = $P{branch_code}
AND SUBSTR (L.ACCOUNT_CODE, 5, 3) = $P{product_code}
) ORDER BY ACCOUNT_CODE, DATEACCOUNTOPEN) SR_NO]]>
	</queryString>
	<field name="SR_NO" class="java.math.BigDecimal"/>
	<field name="ACCOUNT_CODE" class="java.lang.String"/>
	<field name="PRODUCT_CODE" class="java.lang.String"/>
	<field name="AC_NAME" class="java.lang.String"/>
	<field name="TDACCOUNT_CODE" class="java.lang.String"/>
	<field name="DATEACCOUNTOPEN" class="java.sql.Timestamp"/>
	<field name="ACCOUNTREVIEWDATE" class="java.sql.Timestamp"/>
	<field name="DEPOSITAMOUNT" class="java.math.BigDecimal"/>
	<field name="SANCTIONAMOUNT" class="java.math.BigDecimal"/>
	<field name="RETURN_DATE" class="java.lang.String"/>
	<field name="OFFICER_SIGN" class="java.lang.String"/>
	<field name="CUSTOMER_SIGN" class="java.lang.String"/>
	<field name="DETAILS" class="java.lang.String"/>
	<field name="PRODUCT_NAME" class="java.lang.String"/>
	<variable name="totaldeposit" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{DEPOSITAMOUNT}]]></variableExpression>
	</variable>
	<variable name="totalsanction" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{SANCTIONAMOUNT}]]></variableExpression>
	</variable>
