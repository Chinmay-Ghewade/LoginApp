	</parameter>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["./"]]></defaultValueExpression>
	</parameter>
	<parameter name="ed_no" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="month_year" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select em.emp_no,em.emp_name,nvl(em.branch_code,' ') branch_code,
				 payroll.Fn_Get_Emp_Branch($P{branch_code}),ed.description, pt.amount,
				 (select amount basic
FROM payroll.payroll_table pt1
where pt.emp_no=pt1.emp_no
         and ed_no = 30
				 and month_year = $P{month_year}) BASIC_SAL, em.PFNUMBER,
nvl(FN_GET_BR_NAME(em.branch_code),' ') br_name,ed.ed_no,nvl(em.desig_code,' ') desig_code,
(em.branch_code ||','|| FN_GET_BR_NAME(em.branch_code)) branch_nm

from payroll.employee_mst em ,
     payroll.payroll_table pt,
     payroll.earning_deduction_master ed
where em.emp_no=pt.emp_no
         and pt.ed_no= ed.ed_no
         and ed.ed_no = $P{ed_no}
         and pt.month_year = $P{month_year}
         and em.left_code=1
         and  pt.amount>0
and em.branch_code = $P{branch_code}
order by em.branch_code,em.desig_code,em.emp_no]]>
	</queryString>
	<field name="EMP_NO" class="java.lang.String"/>
	<field name="EMP_NAME" class="java.lang.String"/>
	<field name="BRANCH_CODE" class="java.lang.String"/>
	<field name="PAYROLL.FN_GET_EMP_BRANCH(:1)" class="java.lang.String"/>
	<field name="DESCRIPTION" class="java.lang.String"/>
	<field name="AMOUNT" class="java.math.BigDecimal"/>
	<field name="BASIC_SAL" class="java.math.BigDecimal"/>
