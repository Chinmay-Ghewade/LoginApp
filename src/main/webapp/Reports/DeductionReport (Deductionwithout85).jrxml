	<field name="BR_NAME" class="java.lang.String"/>
	<field name="ED_NO" class="java.math.BigDecimal"/>
	<field name="DESIG_CODE" class="java.lang.String"/>
	<field name="BRANCH_NM" class="java.lang.String"/>
	<variable name="basic_sum" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{BASIC_SAL}]]></variableExpression>
	</variable>
	<variable name="amount_sum" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{AMOUNT}]]></variableExpression>
	</variable>
