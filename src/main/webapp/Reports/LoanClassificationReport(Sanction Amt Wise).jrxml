	</parameter>
	<queryString>
		<![CDATA[SELECT
    FROMSANCTION || ' To ' || TOSANCTION AS SANCTIONAMOUNT,
    COUNT(ACCOUNT_CODE) AS NOOFACCOUNTS,
    SUM(SANCTIONAMOUNT) AS BALANCE
FROM
    TEMP.LOANCLASS,
    TEMP.SANCTIONWISELOAN
WHERE
    BRANCH_CODE = $P{branch_code}
    AND ABS(SANCTIONAMOUNT) BETWEEN FROMSANCTION AND TOSANCTION
GROUP BY
    FROMSANCTION, TOSANCTION
ORDER BY
    FROMSANCTION, TOSANCTION]]>
	</queryString>
