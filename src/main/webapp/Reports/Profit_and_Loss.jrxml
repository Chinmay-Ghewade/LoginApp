	<queryString>
		<![CDATA[SELECT DECODE(INCOME_BOLD_NORMAL,'B',INCOME_DESC,'') as BOLD, DECODE(INCOME_BOLD_NORMAL,'N',INCOME_DESC,'') as NORMAL,
TO_NUMBER(DECODE(INCOME_INNER_AMT,0,'',ABS(INCOME_INNER_AMT))) AS INCOME_INNER_AMT,
TO_NUMBER(DECODE(INCOME_OUTER_AMT,0,'',ABS(INCOME_OUTER_AMT))) AS INCOME_OUTER_AMT,
DECODE(EXPENSES_BOLD_NORMAL,'B',EXPENSES_DESC,'') as BOLD1, DECODE(EXPENSES_BOLD_NORMAL,'N',EXPENSES_DESC,'') as NORMAL1,
TO_NUMBER(DECODE(EXPENSES_INNER_AMT,0,'',ABS(EXPENSES_INNER_AMT))) AS EXPENSES_INNER_AMT,
TO_NUMBER(DECODE(EXPENSES_OUTER_AMT,0,'',ABS(EXPENSES_OUTER_AMT))) AS EXPENSES_OUTER_AMT
FROM TEMP.TEMP_PL_STRUCTURE
 WHERE BRANCH_CODE =$P{branch_code}
order by SR_NO]]>
	</queryString>
	<field name="BOLD" class="java.lang.String"/>
	<field name="NORMAL" class="java.lang.String"/>
	<field name="INCOME_INNER_AMT" class="java.math.BigDecimal"/>
	<field name="INCOME_OUTER_AMT" class="java.math.BigDecimal"/>
	<field name="BOLD1" class="java.lang.String"/>
	<field name="NORMAL1" class="java.lang.String"/>
	<field name="EXPENSES_INNER_AMT" class="java.math.BigDecimal"/>
	<field name="EXPENSES_OUTER_AMT" class="java.math.BigDecimal"/>
	<variable name="sumExpInnerAmt" class="java.math.BigDecimal" resetType="Page" calculation="Sum">
		<variableExpression><![CDATA[$F{EXPENSES_INNER_AMT}]]></variableExpression>
	</variable>
	<variable name="sumExpOuterAmt" class="java.lang.String"/>
	<variable name="sumIncomeInnerAmt" class="java.math.BigDecimal" resetType="Page" calculation="Sum">
		<variableExpression><![CDATA[$F{INCOME_INNER_AMT}]]></variableExpression>
	</variable>
	<variable name="sumIncomeOuterAmt" class="java.math.BigDecimal" resetType="Page" calculation="Sum">
		<variableExpression><![CDATA[$F{INCOME_OUTER_AMT}]]></variableExpression>
	</variable>
	<variable name="ex_total" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{EXPENSES_OUTER_AMT}]]></variableExpression>
	</variable>
	<variable name="inc_total" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{INCOME_OUTER_AMT}]]></variableExpression>
	</variable>
