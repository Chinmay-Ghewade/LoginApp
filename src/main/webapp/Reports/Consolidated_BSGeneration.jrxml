	</parameter>
	<queryString>
		<![CDATA[SELECT 0 as SR_NO, 'AUTHORISED SHARES CAPITAL' AS LIAB_BOLD, '' AS LIAB_DESC, TO_NUMBER('') LIAB_INNER_AMT,
to_char(FN_GET_SHARE_AUTCAP_LMT($P{as_on_date}), '99,99,99,999.99') AS LIAB_AMT_BOLD,  TO_NUMBER('') LIAB_OUTER_AMT,
TO_NUMBER('')  LIAB_AMT, TO_NUMBER('')  ASSET_BOLD, '' ASSET_DESC, TO_NUMBER('') ASSET_INNER_AMT,
TO_NUMBER('') ASSET_AMT_BOLD, TO_NUMBER('') ASSET_OUTER_AMT, TO_NUMBER('') ASSET_AMT
FROM DUAL

UNION ALL

SELECT  sr_no,
decode(LIAB_BOLD_NORMAL, 'B', LIAB_DESC, '') LIAB_BOLD,
decode(LIAB_BOLD_NORMAL, 'N', LIAB_DESC, '') LIAB_DESC,
decode(LIAB_INNER_AMT, 0, '', to_char(ABS(LIAB_INNER_AMT), '99,99,99,99,99,999.99')) AS LIAB_INNER_AMT,
decode(LIAB_BOLD_NORMAL, 'B',  to_char(ABS(LIAB_OUTER_AMT), '99,99,99,99,99,999.99'), '') LIAB_AMT_BOLD,
decode(LIAB_BOLD_NORMAL, 'N', decode(LIAB_OUTER_AMT, 0, '', to_char(ABS(LIAB_OUTER_AMT), '99,99,99,999.99')), '') AS LIAB_OUTER_AMT,
ABS(LIAB_OUTER_AMT) LIAB_AMT,
decode(ASSET_BOLD_NORMAL, 'B', ASSET_DESC, '') ASSET_BOLD,
decode(ASSET_BOLD_NORMAL, 'N', ASSET_DESC, '') ASSET_DESC,
decode(ASSET_INNER_AMT, 0, '',to_char(ABS(ASSET_INNER_AMT), '99,99,99,99,99,999.99')) AS ASSET_INNER_AMT,
decode(ASSET_BOLD_NORMAL, 'B',  to_char(ABS(ASSET_OUTER_AMT), '99,99,99,99,99,999.99'), '') ASSET_AMT_BOLD,
decode(ASSET_BOLD_NORMAL, 'N', decode(ASSET_OUTER_AMT, 0, '',to_char(ABS(ASSET_OUTER_AMT), '99,99,99,999.99')), '') AS ASSET_OUTER_AMT,
ABS(ASSET_OUTER_AMT) ASSET_AMT
FROM TEMP.CONSOLIDATED_BS
ORDER BY SR_NO]]>
	</queryString>
	<field name="SR_NO" class="java.math.BigDecimal"/>
	<field name="LIAB_BOLD" class="java.lang.String"/>
	<field name="LIAB_DESC" class="java.lang.String"/>
	<field name="LIAB_INNER_AMT" class="java.lang.String"/>
	<field name="LIAB_AMT_BOLD" class="java.lang.String"/>
	<field name="LIAB_OUTER_AMT" class="java.lang.String"/>
	<field name="LIAB_AMT" class="java.math.BigDecimal"/>
	<field name="ASSET_BOLD" class="java.lang.String"/>
	<field name="ASSET_DESC" class="java.lang.String"/>
	<field name="ASSET_INNER_AMT" class="java.lang.String"/>
	<field name="ASSET_AMT_BOLD" class="java.lang.String"/>
	<field name="ASSET_OUTER_AMT" class="java.lang.String"/>
	<field name="ASSET_AMT" class="java.math.BigDecimal"/>
	<variable name="liab_out" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{LIAB_AMT}]]></variableExpression>
	</variable>
	<variable name="asset_out" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{ASSET_AMT}]]></variableExpression>
	</variable>
