<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="TopLoanHousingRG" language="groovy" pageWidth="793" pageHeight="842" columnWidth="753" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="f1ba73bf-193a-487a-967a-cff5f095252e">
	<property name="ireport.zoom" value="1.5"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="as_on_date" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="branch_code" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="report_title" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="user_id" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="no_of_accounts" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["./"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select rownum as sr_no,account_code,name,balance,sanction_amt from
 (select account_code,name,balance,sanction_amt from
(SELECT a.account_code account_code, a.name name ,
(select nvl(sum(decode(substr(t.transactionindicator_code,3,2),'DR',nvl(t.amount,0),-1*nvl(t.amount,0))),0)
 from transaction.transaction_ht_view t
 where t.account_code = a.account_code and t.txn_Date > $P{as_on_date}
 and  t.TRANSACTIONSTATUS='A' ) + b.LEDGERBALANCE balance, l.SANCTIONAMOUNT sanction_amt
 FROM account.account a,ACCOUNT.ACCOUNTLOAN l, balance.ACCOUNT b
 WHERE a.account_code = l.account_code and l.account_code=b.account_code ORDER BY  a.account_code )
 where balance <>0 order by sanction_amt desc) loantop where rownum<=$P{no_of_accounts}]]>
	</queryString>
	<field name="SR_NO" class="java.math.BigDecimal"/>
	<field name="ACCOUNT_CODE" class="java.lang.String"/>
	<field name="NAME" class="java.lang.String"/>
	<field name="BALANCE" class="java.math.BigDecimal"/>
	<field name="SANCTION_AMT" class="java.math.BigDecimal"/>
	<variable name="TOTAL_BALANCE" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{BALANCE}]]></variableExpression>
	</variable>
	<variable name="TOTAL_SANCTION_AMT" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{SANCTION_AMT}]]></variableExpression>
	</variable>
