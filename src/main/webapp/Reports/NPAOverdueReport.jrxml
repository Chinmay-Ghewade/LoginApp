	<parameter name="branch_code" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="as_on_date" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="report_title" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["./"]]></defaultValueExpression>
	</parameter>
	<parameter name="user_id" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="product_code" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT account_code,substr(account_code, 5,3) product, name, mobile, open_d, address,
				due_d, disb, inst, prin, intamt, prin_ovd_amt,charges,descr, installment
				from (select l.account_code account_code ,a.name as name, (trim(c.address1) || ' ' || trim(c.address2) || ' ' || trim(c.address3)) as address,
				c.phonemobile as mobile, to_char(a.dateaccountopen,'DD/MM/YY') as open_d,
				to_char(l.accountreviewdate,'DD/MM/YY') as due_d, nvl(l.DISBURESED_AMOUNT,0) disb, nvl(l.INSTALLMENTAMOUNT,0) inst,
				b.ledgerbalance prin, l.INTEREST_RECEIVABLE intamt, nvl(h.PRINCIPAL_OVERDUE,0) prin_ovd_amt,
				(h.PRINCIPAL_OVERDUE + l.INTEREST_RECEIVABLE + l.postage) as charges, p.description as descr,
				 case when l.installmentamount = 0 or h.principal_overdue = 0
				 then 0 else round(h.principal_overdue/ l.installmentamount) end as installment
FROM history.tlccoverdueadvance h, ACCOUNT.ACCOUNT a, account.accountloan l, balance.account b,
headoffice.product p, customer.customer c
WHERE  substr(l.account_code,1,4) =$P{branch_code}
 and l.account_code=a.account_code
and l.account_code = h.account_code and l.account_code = b.account_code and substr(l.account_code,5,3) = p.product_code and a.customer_id = c.customer_id
and substr(l.account_code,5,3) = $P{product_code}
and h.ovd_adv_date =  $P{as_on_date}
order by a.account_code)]]>
	</queryString>
