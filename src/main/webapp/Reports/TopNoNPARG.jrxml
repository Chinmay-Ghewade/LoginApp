<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="TopNoNPARG" language="groovy" pageWidth="823" pageHeight="842" columnWidth="783" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="8660894d-db69-4d02-bba7-3fd4b14f8a4e">
	<property name="ireport.zoom" value="1.5"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="as_on_date" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="branch_code" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="report_title" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="user_id" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["./"]]></defaultValueExpression>
	</parameter>
	<parameter name="no_of_accounts" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select rownum as sr_no,account_code,name,sanction_d,sanction_amt,balance,overdue
 from (select h.ACCOUNT_CODE account_code,a.NAME name ,to_char(l.SANCTIONDATE,'DD/MM/YYYY')
 sanction_d, l.SANCTIONAMOUNT sanction_amt,h.BALANCE_OUTSTANDING balance, o.PRINCIPAL_OVERDUE overdue
 from bankdata.NPA_GSCB_GOA_HISTORY h,  account.account a, history.TLCCOVERDUEADVANCE o,account.accountloan l
 where a.account_code=h.account_code
 and h.account_code=o.account_code
 and o.account_code=l.account_code and h.to_date= $P{as_on_date}
 and o.OVD_ADV_DATE= $P{as_on_date}
and (h.STD_ASSET + h.AGRIPRODUCT)=0 order by o.PRINCIPAL_OVERDUE  desc ) topnpa
        where rownum <=$P{no_of_accounts}
         order by sr_no, account_code]]>
	</queryString>
	<field name="SR_NO" class="java.math.BigDecimal"/>
	<field name="ACCOUNT_CODE" class="java.lang.String"/>
	<field name="NAME" class="java.lang.String"/>
	<field name="SANCTION_D" class="java.lang.String"/>
	<field name="SANCTION_AMT" class="java.math.BigDecimal"/>
	<field name="BALANCE" class="java.math.BigDecimal"/>
	<field name="OVERDUE" class="java.math.BigDecimal"/>
	<variable name="TOTAL_SANCTION_AMT" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{SANCTION_AMT}]]></variableExpression>
	</variable>
	<variable name="TOTAL_BALANCE" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{BALANCE}]]></variableExpression>
	</variable>
	<variable name="TOTAL_OVERDUE" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{OVERDUE}]]></variableExpression>
	</variable>
