	<queryString>
		<![CDATA[SELECT
    M.EMP_NO,
    M.EMP_NAME,
    M.BASIC_SAL,
    N.DESCRIPTION
FROM
    PAYROLL.EMPLOYEE_MST M,
    PAYROLL.BANK_CODE_MAS N
WHERE
    M.BRANCH_CODE = $P{branch_code}
    AND M.DESIG_CODE = N.SUB_CODE
    AND N.MAIN_CODE IN (16)
    AND LEFT_CODE = '1'
ORDER BY M.DESIG_CODE, M.EMP_NO]]>
	</queryString>
	<field name="EMP_NO" class="java.lang.String"/>
	<field name="EMP_NAME" class="java.lang.String"/>
	<field name="BASIC_SAL" class="java.math.BigDecimal"/>
	<field name="DESCRIPTION" class="java.lang.String"/>
