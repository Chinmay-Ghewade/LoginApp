	<queryString>
		<![CDATA[SELECT  ROWNUM SR_NO, BRANCH_CODE,BRANCH_NAME,TOT_VOUCHERS,TOT_CREDIT_VOUCHERS,TOT_DEBIT_VOUCHERS
FROM (SELECT T.BRANCH_CODE BRANCH_CODE,B.NAME BRANCH_NAME ,COUNT(*)   TOT_VOUCHERS,
		 COUNT(DECODE(SUBSTR(T.TRANSACTIONINDICATOR_CODE,3,2),'CR','*',NULL)) TOT_CREDIT_VOUCHERS,
		 COUNT(DECODE(SUBSTR(T.TRANSACTIONINDICATOR_CODE,3,2),'DR','*',NULL)) TOT_DEBIT_VOUCHERS
FROM TRANSACTION.DAILYTXN T,HEADOFFICE.BRANCH B
 WHERE TXN_DATE>=$P{from_date}
 AND T.TXN_DATE <= $P{to_date}
 AND T.BRANCH_CODE = B.BRANCH_CODE
 GROUP BY T.BRANCH_CODE,B.NAME ORDER BY T.BRANCH_CODE )]]>
	</queryString>
	<field name="SR_NO" class="java.math.BigDecimal"/>
	<field name="BRANCH_CODE" class="java.lang.String"/>
	<field name="BRANCH_NAME" class="java.lang.String"/>
	<field name="TOT_VOUCHERS" class="java.math.BigDecimal"/>
	<field name="TOT_CREDIT_VOUCHERS" class="java.math.BigDecimal"/>
	<field name="TOT_DEBIT_VOUCHERS" class="java.math.BigDecimal"/>
	<variable name=" Total Vouchers" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{TOT_VOUCHERS}]]></variableExpression>
	</variable>
	<variable name="Total Credit Vouchers" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{TOT_CREDIT_VOUCHERS}]]></variableExpression>
	</variable>
	<variable name="Total Debit Vouchers" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{TOT_DEBIT_VOUCHERS}]]></variableExpression>
	</variable>
