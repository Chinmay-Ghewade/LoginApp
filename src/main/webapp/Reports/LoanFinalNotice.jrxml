	<queryString>
		<![CDATA[SELECT AL.DISBURESED_AMOUNT, AL.ACCOUNTREVIEWDATE, A.DATEACCOUNTOPEN, ABS(B.LEDGERBALANCE) AS BALANCE,
		A.NAME, (C.ADDRESS1 || ' ' || C.ADDRESS2 ||' ' || C.ADDRESS3) AS ADDRESS, AL.ACCOUNT_CODE
		FROM ACCOUNT.ACCOUNTLOAN AL, ACCOUNT.ACCOUNT A, BALANCE.ACCOUNT B, CUSTOMER.CUSTOMER C
		WHERE SUBSTR(AL.ACCOUNT_CODE, 0, 4) = $P{branch_code}
		AND AL.ACCOUNT_CODE = $P{account_code}
		AND A.ACCOUNT_CODE = AL.ACCOUNT_CODE
    AND AL.ACCOUNT_CODE = B.ACCOUNT_CODE
		AND A.CUSTOMER_ID = C.CUSTOMER_ID]]>
	</queryString>
