				<reportElement x="244" y="170" width="306" height="20" uuid="3414560a-14d3-45c7-aa1c-913095e67a80"/>
				<text><![CDATA[ You are not regular in repayment of the loan. The loan is overdue by ]]></text>
			</staticText>
			<textField>
				<reportElement x="20" y="190" width="34" height="20" uuid="c06b03c0-6133-473e-944d-b41c1063795e"/>
