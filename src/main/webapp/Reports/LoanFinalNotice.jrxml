			</textField>
			<staticText>
				<reportElement x="249" y="250" width="286" height="20" uuid="b8c78ed9-9adf-4801-994b-1f8883e78afd"/>
				<text><![CDATA[ plus interest w.e.f. on or before __________. In case the]]></text>
			</staticText>
			<staticText>
				<reportElement x="19" y="270" width="502" height="20" uuid="105620c6-3099-442d-a877-fc89d2082e08"/>
				<text><![CDATA[amount is not paid we shall be proceeding against you by the filling criminal as well as civil suits against you and ]]></text>
			</staticText>
			<staticText>
				<reportElement x="19" y="290" width="303" height="20" uuid="71df4ddf-09f9-42c2-b750-fc67f038cf66"/>
				<text><![CDATA[sureties entirely at your risk,cost and responsibility.]]></text>
			</staticText>
			<staticText>
				<reportElement x="45" y="310" width="510" height="20" uuid="f2d20eb3-f1fa-470f-a359-9c9338f719dc"/>
				<text><![CDATA[No further reminders will be sent to you in this respect. We are sure that you will do the needful and cooperate.]]></text>
			</staticText>
