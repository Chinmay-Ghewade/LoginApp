			<staticText>
				<reportElement x="45" y="210" width="510" height="20" uuid="62ee5d3e-0c24-429c-aff3-4de0760a4519"/>
				<text><![CDATA[ We have contacted you on various occasion and you had assured to regularize the account but no steps have been  ]]></text>
			</staticText>
			<staticText>
				<reportElement x="19" y="230" width="303" height="20" uuid="6ee99589-c4a6-48ac-8536-932aa3e6fa2e"/>
				<text><![CDATA[taken by you in this respect. We are unable to keep matter pending.]]></text>
			</staticText>
			<staticText>
				<reportElement x="45" y="250" width="176" height="20" uuid="46d8518c-01f3-4271-bbe7-5b076e62f9a1"/>
				<text><![CDATA[We now call upon you to pay the entire balance of]]></text>
			</staticText>
			<textField>
				<reportElement x="221" y="250" width="29" height="20" uuid="7cd215d2-a9c1-4af4-96bb-4c58a06a5378"/>
