	<queryString>
		<![CDATA[SELECT TO_NUMBER(SUBSTR(L.ACCOUNT_CODE,8,7)) ACCOUNT_CODE,SUBSTR(L.ACCOUNT_CODE,5,3) PRODUCT_CODE,
fn_get_product_name(SUBSTR(L.ACCOUNT_CODE,5,3)) PRODUCT_NAME,        Fn_Get_Account_name(L.ACCOUNT_CODE) NAME,
fn_get_account_address(L.ACCOUNT_CODE) ADDRES,
TO_CHAR(AB.DATEACCOUNTOPEN,'DD/MM/YYYY') DATEACCOUNTOPEN ,
TO_CHAR(L.ACCOUNTREVIEWDATE,'DD/MM/YYYY') ACCOUNTREVIEWDATE,TEMP.PARTICULAR,
TEMP.GROSTOTALGMS, TEMP.WEIGHTTOTALGMS,TEMP.SECURITYVALUE,L.SANCTIONAMOUNT
FROM ACCOUNT.ACCOUNTLOAN L,ACCOUNT.ACCOUNT AB,
(SELECT S.ACCOUNT_CODE,trim(S.PARTICULAR) PARTICULAR,
			S.GROSTOTALGMS GROSTOTALGMS,
			S.WEIGHTTOTALGMS WEIGHTTOTALGMS,
		(S.RATEPER10GMS * S.WEIGHTTOTALGMS) SECURITYVALUE
FROM ACCOUNT.ACCOUNTSECURITYGOLDSILVER S,ACCOUNT.ACCOUNT A
where S.ACCOUNT_CODE=A.ACCOUNT_CODE(+)
and A.DATEACCOUNTCLOSE IS NULL
--and A.DATEACCOUNTOPEN BETWEEN CDATE('16-JUN-18')
--AND CDATE('16-JUN-18')
--AND SUBSTR(S.ACCOUNT_CODE,1,4)= '0002'
--AND SUBSTR(S.ACCOUNT_CODE,5,3)= '515'
ORDER BY S.ACCOUNT_CODE) TEMP
 WHERE TEMP.ACCOUNT_CODE=L.ACCOUNT_CODE(+)  AND TEMP.ACCOUNT_CODE=AB.ACCOUNT_CODE(+)]]>
	</queryString>
