<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="bnkrptCityWiseMemberList1" language="groovy" pageWidth="909" pageHeight="864" orientation="Landscape" columnWidth="869" leftMargin="20" rightMargin="20" topMargin="3" bottomMargin="7" uuid="cb69953d-3b75-4464-bc11-2a9b4800e1c5">
