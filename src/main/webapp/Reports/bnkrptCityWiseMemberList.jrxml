	</parameter>
	<parameter name="report_title" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="as_on_date" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["./"]]></defaultValueExpression>
	</parameter>
	<parameter name="from_city" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="to_city" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select srno,
       ACCOUNT_CODE,
       NAME,
       DATEACCOUNTOPEN,
       DATEACCOUNTCLOSE,
       ADDRESS,
       CITY_NAME,
       AC_GENDER,
       CITY_CODE,
       Bal_amount
from(
SELECT rownum srno,
       A.ACCOUNT_CODE,
       A.NAME,
       to_char(A.DATEACCOUNTOPEN,'dd/mm/yyyy') DATEACCOUNTOPEN,
       to_char(A.DATEACCOUNTCLOSE,'dd/mm/yyyy') DATEACCOUNTCLOSE,
       C.ADDRESS1||C.ADDRESS2 ADDRESS,

       Fn_get_city_NAME(C.CITY_CODE) CITY_NAME,
       M.NAME CITY_NAME_2,
       C.CITY_CODE,
       DECODE(C.GENDER,'F','FEMALE','MALE') AC_GENDER,
       fn_get_balance_ason($P{as_on_date},A.ACCOUNT_CODE) as Bal_amount

FROM   ACCOUNT.ACCOUNT A ,
       CUSTOMER.CUSTOMER C,
       globalconfig.city M

WHERE A.CUSTOMER_ID=C.CUSTOMER_ID
     AND C.CITY_CODE=M.CITY_CODE
    AND  SUBSTR(A.ACCOUNT_CODE,1,4)= $P{branch_code}
     AND  SUBSTR(A.ACCOUNT_CODE,5,3)=901
    and  fn_get_balance_ason($P{as_on_date},A.ACCOUNT_CODE)<>0
    AND (A.DATEACCOUNTCLOSE IS NULL OR A.DATEACCOUNTCLOSE >
    TO_DATE($P{as_on_date},'dd/mm/yyyy'))
   AND (A.DATEACCOUNTOPEN IS NULL OR A.DATEACCOUNTOPEN <=
    TO_DATE($P{as_on_date},'dd/mm/yyyy'))

AND M.CITY_CODE between $P{from_city}  and $P{to_city}
)
order by CITY_CODE]]>
	</queryString>
