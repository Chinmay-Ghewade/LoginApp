		<defaultValueExpression><![CDATA["./"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
    D.ACCOUNT_CODE,
    D.DEPOSITAMOUNT,
    TO_CHAR(D.MATURITYDATE,'DD/MM/YYYY') MATURITYDATE,
    TO_CHAR(A.DATEACCOUNTOPEN,'DD/MM/YYYY') DATEACCOUNTOPEN,
    R.RECEIPT_NUMBER,
    A.NAME,
    C.ADDRESS1||' '||C.ADDRESS2||' '||C.ADDRESS3 ADDRESS
FROM
    ACCOUNT.ACCOUNTDEPOSIT D,
    ACCOUNT.RECEIPT_INVENTORY R,
    ACCOUNT.ACCOUNT A,
    CUSTOMER.CUSTOMER C
WHERE
  D.ACCOUNT_CODE = A.ACCOUNT_CODE
AND D.ACCOUNT_CODE = R.ACCOUNT_CODE
--AND A.CUSTOMER_ID = C.CUSTOMER_ID
--AND A.ACCOUNT_STATUS IN ('L','M')
--AND A.DATEACCOUNTCLOSE IS NULL
AND SUBSTR(D.ACCOUNT_CODE,1,4)=$P{branch_code}
AND D.MATURITYDATE BETWEEN $P{from_date} AND $P{To_date}
ORDER BY D.ACCOUNT_CODE]]>
	</queryString>
	<field name="ACCOUNT_CODE" class="java.lang.String"/>
	<field name="DEPOSITAMOUNT" class="java.math.BigDecimal"/>
	<field name="MATURITYDATE" class="java.lang.String"/>
	<field name="DATEACCOUNTOPEN" class="java.lang.String"/>
	<field name="RECEIPT_NUMBER" class="java.math.BigDecimal"/>
	<field name="NAME" class="java.lang.String"/>
	<field name="ADDRESS" class="java.lang.String"/>
