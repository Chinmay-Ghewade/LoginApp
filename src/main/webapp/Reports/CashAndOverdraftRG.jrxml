<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="CashAndOverdraftRG" language="groovy" pageWidth="799" pageHeight="842" columnWidth="759" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="eb40c9f4-271c-411f-a5ab-ea778042eba0">
	<property name="ireport.zoom" value="1.5"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="as_on_date" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="branch_code" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="report_title" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="user_id" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["./"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT    H.BRANCH_CODE  AS BRCODE  ,b.name AS BRNAME ,
		 ABS(SUM(DECODE(A.FINAL_GROUP_MAIN_CODE,'CH',H.OPENINGBALANCE+(H.CREDITCASH+H.CREDITTRANSFER+H.CREDITCLEARING)- (H.DEBITCASH+H.DEBITTRANSFER+H.DEBITCLEARING),0)))AS CASHINHAND,
		 ABS(SUM(DECODE(A.FINAL_GROUP_MAIN_CODE,'CB',H.OPENINGBALANCE+(H.CREDITCASH+H.CREDITTRANSFER+H.CREDITCLEARING)- (H.DEBITCASH+H.DEBITTRANSFER+H.DEBITCLEARING),0)))AS CASHATBANK,
		 ABS(SUM(DECODE(A.FINAL_GROUP_MAIN_CODE,'OD',H.OPENINGBALANCE+(H.CREDITCASH+H.CREDITTRANSFER+H.CREDITCLEARING)- (H.DEBITCASH+H.DEBITTRANSFER+H.DEBITCLEARING),0)))AS OVERDRAFT
		 FROM BALANCE.BRANCHGLHISTORY H,HEADOFFICE.GLACCOUNT A,headoffice.BRANCH b
		 WHERE   H.GLACCOUNT_CODE=A.GLACCOUNT_CODE
		 AND H.TXN_DATE= $P{as_on_date}
		 --AND A.FINAL_GROUP_MAIN_CODE IN ('CH','CB','OD')
		 and h.branch_code=b.branch_code
		 GROUP BY ( H.BRANCH_CODE ,b.name)
		 ORDER BY H.BRANCH_CODE]]>
	</queryString>
	<field name="BRCODE" class="java.lang.String"/>
	<field name="BRNAME" class="java.lang.String"/>
	<field name="CASHINHAND" class="java.math.BigDecimal"/>
	<field name="CASHATBANK" class="java.math.BigDecimal"/>
	<field name="OVERDRAFT" class="java.math.BigDecimal"/>
	<variable name="TOTAL_CASHINHAND" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{CASHINHAND}]]></variableExpression>
	</variable>
	<variable name="TOTAL_CASHATBANK" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{CASHATBANK}]]></variableExpression>
	</variable>
	<variable name="TOTAL_OVERDRAFT" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{OVERDRAFT}]]></variableExpression>
	</variable>
