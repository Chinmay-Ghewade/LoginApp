	<queryString>
		<![CDATA[SELECT BRANCH_CODE,FROMDATE,TODATE,TXN_DATE,ACCOUNT_CODE,SHARE_NUMBER,FORACCOUNT_CODE,
  CUSTOMER_ID,Fn_Get_Account_name(FORACCOUNT_CODE) NAME,TRANSACTIONINDICATOR_CODE,initcap(PARTICULAR)PARTICULAR ,AMOUNT,
substr(FORACCOUNT_CODE,5,3) product_code,
fn_get_product_name(substr(FORACCOUNT_CODE,5,3)) product_name
  FROM TEMP.BTYPE_MEBER_INTEREST WHERE SUBSTR(SHARE_NUMBER,5,3) NOT IN ('901')
AND  FROMDATE=$P{from_date} AND TODATE=$P{to_date}
and substr(FORACCOUNT_CODE,1,4)=$P{branch_code}
ORDER BY FORACCOUNT_CODE,TXN_DATE]]>
	</queryString>
