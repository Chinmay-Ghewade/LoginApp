<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="FinancialPositionRG" language="groovy" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="0d91992f-3409-4e14-9491-2d8d8fcb2ae4">
	<property name="ireport.zoom" value="3.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="branch_code" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="as_on_date" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="report_title" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="user_id" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["./"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
    SR_NO,
    DESCRIPTION,
    DECRIPTION2
FROM (
    SELECT
        '1' AS SR_NO,
        'Established On' AS DESCRIPTION,
        TO_CHAR(REGISTRATION_DATE, 'dd/MM/yyyy') AS DECRIPTION2
    FROM
        ACCOUNTLINK.DEFAULTBANKACCOUNTS
    WHERE
        BANK_CODE = $P{branch_code}

    UNION ALL

    SELECT
        '2' AS SR_NO,
        'Members A Class' AS DESCRIPTION,
        TO_CHAR(SUM(NVL(BALANCE, 0))) AS DECRIPTION2
    FROM
        bankdata.FP_MEMBER_DETAILS A
    WHERE
        A.SEQ_NO = '1'
        AND A.user_id = $P{user_id}
        AND A.DATE_AS_ON = $P{as_on_date}

    UNION ALL

    SELECT
        '3' AS SR_NO,
        'Members B Class' AS DESCRIPTION,
        TO_CHAR(SUM(NVL(BALANCE, 0))) AS DECRIPTION2
    FROM
        bankdata.FP_MEMBER_DETAILS A
    WHERE
        A.SEQ_NO = '2'
        AND A.user_id = $P{user_id}
        AND A.DATE_AS_ON = $P{as_on_date}

    UNION ALL

    SELECT
        '4' AS SR_NO,
        'Shares' AS DESCRIPTION,
        TO_CHAR(SUM(NVL(BALANCE, 0))) AS DECRIPTION2
    FROM
        bankdata.fp_cd_ratio A
    WHERE
        A.DESCRIPTION LIKE 'SHARES%'
        AND A.user_id = $P{user_id}
        AND A.DATE_AS_ON = $P{as_on_date}

    UNION ALL

    SELECT
        '5' AS SR_NO,
        'Deposits' AS DESCRIPTION,
        TO_CHAR(SUM(NVL(BALANCE, 0))) AS DECRIPTION2
    FROM
        bankdata.fp_cd_ratio A
    WHERE
        A.SEQ_NO = '06'
        AND A.user_id = $P{user_id}
        AND A.DATE_AS_ON = $P{as_on_date}

    UNION ALL

    SELECT
        '6' AS SR_NO,
        'Available Fund' AS DESCRIPTION,
        TO_CHAR(SUM(NVL(BALANCE, 0))) AS DECRIPTION2
    FROM
        bankdata.fp_cd_ratio A
    WHERE
        A.SEQ_NO = '07'
        AND A.user_id = $P{user_id}
        AND A.DATE_AS_ON = $P{as_on_date}

    UNION ALL

    SELECT
        '7' AS SR_NO,
        'Loans' AS DESCRIPTION,
        TO_CHAR(SUM(NVL(BALANCE, 0))) AS DECRIPTION2
    FROM
        bankdata.fp_cd_ratio A
    WHERE
        A.SEQ_NO = '05'
        AND A.user_id = $P{user_id}
        AND A.DATE_AS_ON = $P{as_on_date}

    UNION ALL

    SELECT
        '8' AS SR_NO,
        'CD Ratio' AS DESCRIPTION,
        TO_CHAR(SUM(NVL(BALANCE, 0))) AS DECRIPTION2
    FROM
        bankdata.fp_cd_ratio A
    WHERE
        A.SEQ_NO = '99'
        AND A.user_id = $P{user_id}
        AND A.DATE_AS_ON = $P{as_on_date}

    UNION ALL

    SELECT
        '9' AS SR_NO,
        'Overdues' AS DESCRIPTION,
        TO_CHAR(SUM(NVL(BALANCE, 0))) AS DECRIPTION2
    FROM
        bankdata.fp_balance_sheet A
    WHERE
        A.SEQ_NO = '10'
        AND A.user_id = $P{user_id}
        AND A.DATE_AS_ON = $P{as_on_date}

    UNION ALL

    SELECT
        '10' AS SR_NO,
        'Overdues Percent' AS DESCRIPTION,
        TO_CHAR(SUM(NVL(BALANCE, 0))) AS DECRIPTION2
    FROM
        bankdata.fp_balance_sheet A
    WHERE
        A.SEQ_NO = '12'
        AND A.user_id = $P{user_id}
        AND A.DATE_AS_ON = $P{as_on_date}

    UNION ALL

    SELECT
        '11' AS SR_NO,
        'Investments' AS DESCRIPTION,
        TO_CHAR(SUM(NVL(BALANCE, 0))) AS DECRIPTION2
    FROM
        bankdata.fp_balance_sheet A
    WHERE
        A.SEQ_NO = '09'
        AND A.user_id = $P{user_id}
        AND A.DATE_AS_ON = $P{as_on_date}

    UNION ALL

    SELECT
        '12' AS SR_NO,
        'Profit' AS DESCRIPTION,
        TO_CHAR(SUM(NVL(BALANCE, 0))) AS DECRIPTION2
    FROM
        bankdata.fp_balance_sheet A
    WHERE
        A.SEQ_NO = '05'
        AND A.user_id = $P{user_id}
        AND A.DATE_AS_ON = $P{as_on_date}

    UNION ALL

    SELECT
        '13' AS SR_NO,
        'Working capital' AS DESCRIPTION,
        TO_CHAR(SUM(NVL(BALANCE, 0))) AS DECRIPTION2
    FROM
        bankdata.fp_balance_sheet A
    WHERE
        A.SEQ_NO = '01'
        AND A.user_id = $P{user_id}
        AND A.DATE_AS_ON = $P{as_on_date}

    UNION ALL

    SELECT
        '14' AS SR_NO,
        'Audit Class' AS DESCRIPTION,
        'A Class' AS DECRIPTION2
    FROM
        DUAL

    UNION ALL

    SELECT
        '15' AS SR_NO,
        'Turnover' AS DESCRIPTION,
        TO_CHAR(SUM(NVL(BALANCE, 0))) AS DECRIPTION2
    FROM
        bankdata.fp_balance_sheet A
    WHERE
        A.SEQ_NO = '07'
        AND A.user_id = $P{user_id}
        AND A.DATE_AS_ON = $P{as_on_date}

    UNION ALL

    SELECT
        '16' AS SR_NO,
        'Self Fund' AS DESCRIPTION,
        TO_CHAR(SUM(NVL(BALANCE, 0))) AS DECRIPTION2
    FROM
        bankdata.fp_balance_sheet A
    WHERE
        A.SEQ_NO = '13'
        AND A.user_id = $P{user_id}
        AND A.DATE_AS_ON = $P{as_on_date}
)]]>
	</queryString>
	<field name="SR_NO" class="java.lang.String"/>
	<field name="DESCRIPTION" class="java.lang.String"/>
	<field name="DECRIPTION2" class="java.lang.String"/>
