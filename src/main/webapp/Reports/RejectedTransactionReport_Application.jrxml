	<queryString>
		<![CDATA[select ROWNUM AS SR_NO,BRANCH_CODE,APPLICATION_NUMBER,PRODUCT_CODE,APPLICATIONDATE,USER_ID,officer_id,NAME,
STATUS,timestamp from(
select a.BRANCH_CODE,a.APPLICATION_NUMBER,a.PRODUCT_CODE,a.APPLICATIONDATE,a.USER_ID,b.officer_id,a.NAME,
a.STATUS,to_char(b.datetimestamp,'DD/MM/YYYY HH.MM.SS') timestamp from application.application a,history.application b
where a.applicationdate>= $P{from_date}
and a.applicationdate<=$P{to_date}  and
a.BRANCH_CODE between $P{branch_code} and $P{to_branch}
and a.status='R' and a.application_number=b.application_number and a.applicationdate = b.applicationdate
order by a.branch_code,a.applicationdate) ]]>
	</queryString>
	<field name="SR_NO" class="java.math.BigDecimal"/>
	<field name="BRANCH_CODE" class="java.lang.String"/>
	<field name="APPLICATION_NUMBER" class="java.lang.String"/>
	<field name="PRODUCT_CODE" class="java.lang.String"/>
