	<parameter name="branch_codefilter%" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT A.ACCOUNT_CODE
      AS ACCOUNT_CODE,
      A.NAME AS NAME ,
      to_char(A.DATEACCOUNTOPEN,'DD-MON-YY') AS A,
                           to_char(B.MATURITYDATE,'DD-MON-YY') AS B ,
                           B.DEPOSITAMOUNT
                           AS DEPOSITAMOUNT,B.PENDINGCASHINTEREST
                           AS PENDINGCASHINTEREST
FROM  ACCOUNT.ACCOUNTDEPOSIT B ,
      ACCOUNT.ACCOUNT A

WHERE B.ACCOUNT_CODE LIKE  $P{branch_codefilter%}
    --AND PENDINGCASHINTEREST >0
    AND A.DATEACCOUNTCLOSE IS NULL
    AND A.ACCOUNT_CODE = B.ACCOUNT_CODE]]>
	</queryString>
	<field name="ACCOUNT_CODE" class="java.lang.String"/>
	<field name="NAME" class="java.lang.String"/>
	<field name="A" class="java.lang.String"/>
	<field name="B" class="java.lang.String"/>
	<field name="DEPOSITAMOUNT" class="java.math.BigDecimal"/>
	<field name="PENDINGCASHINTEREST" class="java.math.BigDecimal"/>
	<variable name="Deposit_Amount" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{DEPOSITAMOUNT}]]></variableExpression>
	</variable>
