<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="FreezeAccountReport" pageWidth="1057" pageHeight="595" orientation="Landscape" columnWidth="1017" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="a3b84a62-9d0d-4cf8-8f14-6d8b2b2d0f91">
	<property name="ireport.zoom" value="1.6105100000000008"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="branch_code" class="java.lang.String"/>
	<parameter name="report_title" class="java.lang.String"/>
	<parameter name="as_on_date" class="java.lang.String"/>
	<parameter name="user_id" class="java.lang.String"/>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["./"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
    AF.FREEZEBRANCH_CODE AS FREEZEBRANCH_CODE,

    AF.FREEZEACCOUNT_CODE AS FREEZEACCOUNT_CODE,

    A.NAME AS NAME,

    AF.SERIAL_NUMBER AS SERIAL_NUMBER,

    (
        CASE
            WHEN AF.FREEZE_ALL_PARTIAL_WITHDRAWAL = 'A'
            THEN 'All'

            ELSE
                (
                    CASE
                        WHEN AF.FREEZE_ALL_PARTIAL_WITHDRAWAL = 'P'
                        THEN 'Partial'

                        ELSE
                            (
                                CASE
                                    WHEN AF.FREEZE_ALL_PARTIAL_WITHDRAWAL = 'W'
                                    THEN 'Withdrawal'
                                END
                            )
                    END
                )
        END
    ) AS FREEZE_ALL_PARTIAL_WITHDRAWAL,

    AF.FREEZE_AMOUNT AS FREEZE_AMOUNT,

    AF.FREEZE_DATE AS FREEZE_DATE,

    AF.REASON AS REASON,

    AF.FREEZEUSER_ID AS FREEZEUSER_ID,

    AF.FREEZEOFFICER_ID AS FREEZEOFFICER_ID

FROM ACCOUNT.ACCOUNTFREEZE AF,
     ACCOUNT.ACCOUNT A

WHERE SUBSTR(AF.FREEZEACCOUNT_CODE,1,4)
      = '$P!{branch_code}'

AND AF.FREEZEACCOUNT_CODE = A.ACCOUNT_CODE

AND AF.STATUS = 'A'

ORDER BY
    AF.FREEZEACCOUNT_CODE,
    AF.SERIAL_NUMBER]]>
	</queryString>
	<field name="FREEZEBRANCH_CODE" class="java.lang.String"/>
	<field name="FREEZEACCOUNT_CODE" class="java.lang.String"/>
	<field name="NAME" class="java.lang.String"/>
	<field name="SERIAL_NUMBER" class="java.math.BigDecimal"/>
	<field name="FREEZE_ALL_PARTIAL_WITHDRAWAL" class="java.lang.String"/>
	<field name="FREEZE_AMOUNT" class="java.math.BigDecimal"/>
	<field name="FREEZE_DATE" class="java.sql.Date"/>
	<field name="REASON" class="java.lang.String"/>
	<field name="FREEZEUSER_ID" class="java.lang.String"/>
	<field name="FREEZEOFFICER_ID" class="java.lang.String"/>
	<variable name="TOTAL_FREEZE_AMOUNT" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{FREEZE_AMOUNT}]]></variableExpression>
	</variable>
