	<field name="BR1" class="java.lang.String"/>
	<field name="BR2" class="java.lang.String"/>
	<variable name="Emp_total" class="java.lang.Double">
		<variableExpression><![CDATA[Double.parseDouble($F{BR}) + Double.parseDouble($F{BR1}) +Double.parseDouble($F{BR2})]]></variableExpression>
	</variable>
	<variable name="col_1" class="java.lang.Double" calculation="Sum">
		<variableExpression><![CDATA[Double.parseDouble($F{BR})]]></variableExpression>
	</variable>
	<variable name="col_2" class="java.lang.Double" calculation="Sum">
		<variableExpression><![CDATA[Double.parseDouble($F{BR1})]]></variableExpression>
	</variable>
	<variable name="col_3" class="java.lang.Double" calculation="Sum">
		<variableExpression><![CDATA[Double.parseDouble($F{BR2})]]></variableExpression>
	</variable>
	<variable name="all_total" class="java.lang.Double" calculation="Sum">
		<variableExpression><![CDATA[$V{Emp_total}]]></variableExpression>
	</variable>
