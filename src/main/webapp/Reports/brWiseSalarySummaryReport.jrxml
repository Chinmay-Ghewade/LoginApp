	</parameter>
	<queryString>
		<![CDATA[select emp_no,emp_name,branch_code,(select description from payroll.bank_code_mas where main_code=38 and sub_code=branch_code)br_nm,$P!{account_name} br,$P!{agent_name} br1,$P!{user_id} br2 from (
select emp_no,emp_name,branch_code,(select description from payroll.bank_code_mas where
main_code=38 and sub_code=branch_code)br_nm, sum(January) January,sum(February) February ,
sum(March) March ,sum(April) April ,sum(May) May ,sum(June) June ,sum(July) July ,
sum(August) August ,sum(September) September,sum(October) October,sum(November) November,
sum(December) December from (select emp_no,emp_name,branch_code,
decode (trim(month),'January',(amount),0) January,
decode (trim(month),'February', (amount),0) February  ,
decode (trim(month),'March',(amount),0) March,
decode (trim(month),'April',(amount),0) April,
decode (trim(month),'May', (amount),0) May  ,
decode (trim(month),'June',(amount),0) June,
decode (trim(month),'July',(amount),0) July,
decode (trim(month),'August',(amount),0) August,
decode (trim(month),'September',(amount),0) September,
decode (trim(month),'October', (amount),0) October  ,
decode (trim(month),'November',(amount),0) November,
decode (trim(month),'December',(amount),0) December from(select p.emp_no,m.emp_name,
p.amount,m.branch_code,p.month_year,to_char(to_date(p.month_year,'MM-YYYY'), 'Month') month
FROM payroll.payroll_table p,payroll.employee_mst m where p.emp_no=m.emp_no
and p.ed_no=79 and p.month_year between $P{ac_close_date} and $P{review_date} and m.branch_code=$P{branch_code} order by p.month_year,to_number(Fn_Get_Emp_Desig_code(m.EMP_NO))))
group by emp_no,emp_name,branch_code order  by emp_no)order  by emp_no]]>
	</queryString>
	<field name="EMP_NO" class="java.lang.String"/>
	<field name="EMP_NAME" class="java.lang.String"/>
	<field name="BRANCH_CODE" class="java.lang.String"/>
	<field name="BR_NM" class="java.lang.String"/>
