	</parameter>
	<parameter name="branch_code" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="user_id" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT decode(INCOME_BOLD_NORMAL, 'N', trim(INCOME_DESC), '' ) AS INCOME_DESC,
decode(INCOME_BOLD_NORMAL, 'B', trim(INCOME_DESC), '' ) AS INCOME_BOLD,

decode(INCOME_INNER_AMT, 0, '',  to_char(ABS(INCOME_INNER_AMT), '99,99,99,99,99,999.99')) AS INCOME_INNER_AMT,

decode(INCOME_BOLD_NORMAL, 'B', to_char(ABS(INCOME_OUTER_AMT), '99,99,99,99,99,999.99'), '' ) AS INCOME_AMT_BOLD,
decode(INCOME_BOLD_NORMAL, 'N', decode(INCOME_OUTER_AMT, 0, '', to_char(ABS(INCOME_OUTER_AMT), '99,99,99,999.99')), '' ) AS INCOME_OUTER_AMT,
ABS(INCOME_OUTER_AMT) AS INCOME_AMT,
decode(EXPENSES_BOLD_NORMAL, 'N', trim(EXPENSES_DESC), '' ) AS EXPENSES_DESC,
decode(EXPENSES_BOLD_NORMAL, 'B', trim(EXPENSES_DESC), '' ) AS EXPENSES_BOLD,

decode(EXPENSES_INNER_AMT, 0, '', to_char(ABS(EXPENSES_INNER_AMT), '99,99,99,99,99,999.99')) AS EXPENSES_INNER_AMT,

decode(EXPENSES_BOLD_NORMAL, 'B', to_char(ABS(EXPENSES_OUTER_AMT), '99,99,99,99,99,999.99'), '' ) AS EXPENSES_AMT_BOLD,
decode(EXPENSES_BOLD_NORMAL, 'N', decode(EXPENSES_OUTER_AMT, 0, '', to_char(ABS(EXPENSES_OUTER_AMT), '99,99,99,999.99')), '' ) AS EXPENSES_OUTER_AMT,
ABS(EXPENSES_OUTER_AMT) AS EXPENSES_AMT
FROM TEMP.CONSOLIDATED_PL
ORDER BY SR_NO]]>
	</queryString>
	<field name="INCOME_DESC" class="java.lang.String"/>
	<field name="INCOME_BOLD" class="java.lang.String"/>
	<field name="INCOME_INNER_AMT" class="java.lang.String"/>
	<field name="INCOME_AMT_BOLD" class="java.lang.String"/>
	<field name="INCOME_OUTER_AMT" class="java.lang.String"/>
	<field name="INCOME_AMT" class="java.math.BigDecimal"/>
	<field name="EXPENSES_DESC" class="java.lang.String"/>
	<field name="EXPENSES_BOLD" class="java.lang.String"/>
	<field name="EXPENSES_INNER_AMT" class="java.lang.String"/>
