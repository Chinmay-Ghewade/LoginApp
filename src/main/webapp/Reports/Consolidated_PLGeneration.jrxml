	<field name="EXPENSES_OUTER_AMT" class="java.lang.String"/>
	<field name="EXPENSES_AMT" class="java.math.BigDecimal"/>
	<variable name="exp_out" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{EXPENSES_AMT}]]></variableExpression>
	</variable>
	<variable name="inc_out" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{INCOME_AMT}]]></variableExpression>
	</variable>
