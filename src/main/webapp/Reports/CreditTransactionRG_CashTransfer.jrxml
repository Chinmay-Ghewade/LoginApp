<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="CreditTransactionRG_cash_transfer" language="groovy" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="6a1a8490-f2fe-43dd-a94d-6310e149e819">
	<property name="ireport.zoom" value="2.1435888100000016"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="as_on_date" class="java.lang.String"/>
	<parameter name="report_title" class="java.lang.String"/>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["./"]]></defaultValueExpression>
	</parameter>
	<parameter name="branch_code" class="java.lang.String"/>
	<parameter name="product_code" class="java.lang.String"/>
	<parameter name="from_date" class="java.lang.String"/>
	<parameter name="to_date" class="java.lang.String"/>
	<parameter name="from_amt" class="java.math.BigDecimal"/>
	<parameter name="to_amt" class="java.math.BigDecimal"/>
	<parameter name="user_id" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT ROWNUM AS SR_NO, PRODUCT, DESCRIPTION, ACCOUNT_CODE, NAME, TOTALCREDIT,PAN_NO,ADDRESS FROM
(
    SELECT
        SUBSTR(D.ACCOUNT_CODE,5,3) AS PRODUCT,
        P.DESCRIPTION AS DESCRIPTION,
        D.ACCOUNT_CODE AS ACCOUNT_CODE,
        A.NAME AS NAME,
        SUM(D.AMOUNT) AS TOTALCREDIT,
        fn_get_pancard_no(D.ACCOUNT_CODE) PAN_NO,
        fn_get_account_address(D.ACCOUNT_CODE) ADDRESS
    FROM
        TRANSACTION.DAILYTXN D,
        ACCOUNT.ACCOUNT A,
        HEADOFFICE.PRODUCT P
    WHERE
        D.TXN_DATE BETWEEN
        TO_DATE('$P!{from_date}','DD/MM/YYYY')
        AND
        TO_DATE('$P!{to_date}','DD/MM/YYYY')

        AND SUBSTR(D.ACCOUNT_CODE,5,3) = P.PRODUCT_CODE
        AND D.ACCOUNT_CODE = A.ACCOUNT_CODE
        AND SUBSTR(D.ACCOUNT_CODE, 5,3) = '$P!{product_code}'

        AND (
            TRANSACTIONINDICATOR_CODE = 'CSCR'
            OR TRANSACTIONINDICATOR_CODE = 'TRCR'
        )

        AND D.BRANCH_CODE = '$P!{branch_code}'

    GROUP BY
        D.ACCOUNT_CODE,
        A.NAME,
        P.DESCRIPTION,
        P.PRODUCT_CODE

    ORDER BY
        D.ACCOUNT_CODE,
        A.NAME,
        P.DESCRIPTION,
        P.PRODUCT_CODE
)
WHERE TOTALCREDIT BETWEEN $P{from_amt} AND $P{to_amt}
ORDER BY SR_NO, PRODUCT, ACCOUNT_CODE]]>
	</queryString>
	<field name="SR_NO" class="java.math.BigDecimal"/>
	<field name="PRODUCT" class="java.lang.String"/>
	<field name="DESCRIPTION" class="java.lang.String"/>
	<field name="ACCOUNT_CODE" class="java.lang.String"/>
	<field name="NAME" class="java.lang.String"/>
	<field name="TOTALCREDIT" class="java.math.BigDecimal"/>
	<field name="PAN_NO" class="java.lang.String"/>
	<field name="ADDRESS" class="java.lang.String"/>
	<variable name="PRODUCT_TOTAL" class="java.math.BigDecimal" resetType="Group" resetGroup="PRODUCT_GROUP" calculation="Sum">
		<variableExpression><![CDATA[$F{TOTALCREDIT}]]></variableExpression>
		<initialValueExpression><![CDATA[new java.math.BigDecimal(0)]]></initialValueExpression>
	</variable>
