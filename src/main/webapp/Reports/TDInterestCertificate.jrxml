<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="TDInterestCertificate" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="736425d7-ef63-4bd3-89f2-1b1e7e53f87d">
	<property name="ireport.zoom" value="2.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="169"/>
	<parameter name="FROM_DATE" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="TO_DATE" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="account_code" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="report_title" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="branch_code" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="as_on_date" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["./"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
 AC_CODE,
 AC_NAME,
 depositamount,
 interestrate,
 SUM(NORMAL_AMOUNT + PAYBLE_AMOUNT) TOTAL_PAID
FROM
(
 SELECT
  A.account_code AC_CODE,
  A.name AC_NAME,
  DEPOSIT.DP_AMOUNT depositamount,
  DEPOSIT.INT_RATE interestrate,
  NVL(INT_PAID.NORMAL_AMT,0) NORMAL_AMOUNT,
  NVL(PAYBLE.PAYBLE_AMT,0) PAYBLE_AMOUNT
 FROM account.account A,

 (
  SELECT SUM(amount) PAYBLE_AMT,
         foraccount_code ACCOUNT_NO
  FROM transaction.dailytxn
  WHERE foraccount_code = $P{account_code}
  AND txn_date BETWEEN
      TO_DATE($P{FROM_DATE},'dd/mm/yyyy')
      AND TO_DATE($P{TO_DATE},'dd/mm/yyyy')
  AND transactionindicator_code LIKE '%CR'
  AND particular LIKE 'By Intt%'
  GROUP BY foraccount_code
 ) PAYBLE,

 (
  SELECT SUM(amount) NORMAL_AMT,
         foraccount_code ACCOUNT_NO
  FROM transaction.dailytxn
  WHERE foraccount_code = $P{account_code}
  AND txn_date BETWEEN
      TO_DATE($P{FROM_DATE},'dd/mm/yyyy')
      AND TO_DATE($P{TO_DATE},'dd/mm/yyyy')
  AND transactionindicator_code LIKE '%DR'
  GROUP BY foraccount_code
 ) INT_PAID,

 (
  SELECT account_code AC_NO,
         depositamount DP_AMOUNT,
         interestrate INT_RATE
  FROM account.accountdeposit
  WHERE account_code =$P{account_code}
 ) DEPOSIT

WHERE A.account_code = PAYBLE.account_no(+)
AND A.account_code = INT_PAID.account_no(+)
AND A.account_code = DEPOSIT.ac_no(+)
AND A.account_code = $P{account_code}

) TEMP

GROUP BY
 AC_CODE,
 AC_NAME,
 depositamount,
 interestrate]]>
	</queryString>
	<field name="AC_CODE" class="java.lang.String"/>
	<field name="AC_NAME" class="java.lang.String"/>
	<field name="DEPOSITAMOUNT" class="java.math.BigDecimal"/>
	<field name="INTERESTRATE" class="java.math.BigDecimal"/>
	<field name="TOTAL_PAID" class="java.math.BigDecimal"/>
	<variable name="TotalPaid_sum" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{TOTAL_PAID}]]></variableExpression>
	</variable>
