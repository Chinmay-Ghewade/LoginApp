<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="GoldLoanSubmisionReport" language="groovy" pageWidth="720" pageHeight="864" orientation="Landscape" columnWidth="706" leftMargin="7" rightMargin="7" topMargin="14" bottomMargin="21" uuid="ab8b7dad-9c37-47f9-b322-b3f9b0d32812">
