	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="branch_code" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="from_date" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="to_date" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="product_code" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="report_title" class="java.lang.String"/>
	<parameter name="branch_name" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT  rownum as SR_NO,to_number(substr(L.ACCOUNT_CODE,8,7))ACCOUNT_CODE,
SUBSTR(L.ACCOUNT_CODE,5,3) PRODUCT_CODE,
fn_get_br_name(substr(L.ACCOUNT_CODE,1,4)) branch_name,
fn_get_product_name(SUBSTR(L.ACCOUNT_CODE,5,3)) PRODUCT_NAME,
Fn_Get_Account_name(L.ACCOUNT_CODE) NAME,GOLDRECIEPTNO,
TO_CHAR(AB.DATEACCOUNTOPEN,'DD/MM/YYYY') DATEACCOUNTOPEN ,
TEMP.GROSTOTALGMS, TEMP.WEIGHTTOTALGMS,RATEPER10GMS,
TEMP.SECURITYVALUE,L.SANCTIONAMOUNT
	  FROM ACCOUNT.ACCOUNTLOAN L,ACCOUNT.ACCOUNT AB,
  (
  SELECT S.ACCOUNT_CODE,S.GOLDRECIEPTNO,sum(S.GROSTOTALGMS) GROSTOTALGMS,
       sum(S.WEIGHTTOTALGMS) WEIGHTTOTALGMS,S.RATEPER10GMS RATEPER10GMS,sum((S.WEIGHTTOTALGMS * S.RATEPER10GMS))SECURITYVALUE
	FROM ACCOUNT.ACCOUNTSECURITYGOLDSILVER S,ACCOUNT.ACCOUNT A
	where S.ACCOUNT_CODE=A.ACCOUNT_CODE(+)
          --and A.DATEACCOUNTOPEN BETWEEN CDATE('22-APR-17')
	--AND CDATE('22-APR-17')
	AND SUBSTR(S.ACCOUNT_CODE,1,4)=$P{branch_code}
	--AND SUBSTR(S.ACCOUNT_CODE,5,3)= '115'

          group by s.account_code,S.GOLDRECIEPTNO,S.RATEPER10GMS
          ORDER BY S.ACCOUNT_CODE) TEMP
          WHERE TEMP.ACCOUNT_CODE=L.ACCOUNT_CODE(+)
	AND TEMP.ACCOUNT_CODE=AB.ACCOUNT_CODE(+)
			ORDER BY  SR_NO]]>
	</queryString>
