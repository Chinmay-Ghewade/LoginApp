		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["C:\\Users\\prajk\\eclipse-workspace\\LoginApp\\src\\main\\webapp\\Reports\\"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select  BRCODE,BRNAME, case when pandl > 0 then pandl+PROFIT else 0 end as Profit,
	 	 case when pandl < 0 then abs(pandl)+abs(LOSS) else 0 end as Loss
 from (
 select h.BRANCH_CODE BRCODE,H.NAME BRNAME ,
 (SELECT SUM(NVL(OPENINGBALANCE,0)+(NVL(CREDITCASH,0)+NVL(CREDITTRANSFER,0)+NVL(CREDITCLEARING,0))-(NVL(DEBITCASH,0)+NVL(DEBITTRANSFER,0)+NVL(DEBITCLEARING,0)))
 FROM BALANCE.BRANCHGLHISTORY D WHERE D.BRANCH_CODE=h.branch_Code AND d.TXN_DATE =$P{as_on_date}
AND SUBSTR(D.GLACCOUNT_CODE,9,1)  IN ('3','4'))pandl,
( SELECT NVL(SUM(AMOUNT),0)
 FROM TRANSACTION.TRANSACTION_HT_VIEW
 WHERE TXN_DATE =$P{as_on_date}
 AND BRANCH_CODE=h.branch_Code
 AND TRANSACTIONSTATUS='A' AND PARTICULAR ='By Profit Transfer') PROFIT,
( SELECT NVL(SUM(AMOUNT),0)
 FROM TRANSACTION.TRANSACTION_HT_VIEW
 WHERE TXN_DATE =$P{as_on_date}
 AND BRANCH_CODE=h.branch_Code AND TRANSACTIONSTATUS='A' AND PARTICULAR ='To Loss Transfer') LOSS
 from   HEADOFFICE.BRANCH H  group by h.branch_code ,H.NAME ORDER BY h.BRANCH_CODE  )  abc
 where (abc. profit+abc.loss+abs(abc.pandl))<>0]]>
	</queryString>
	<field name="BRCODE" class="java.lang.String"/>
	<field name="BRNAME" class="java.lang.String"/>
	<field name="PROFIT" class="java.math.BigDecimal"/>
	<field name="LOSS" class="java.math.BigDecimal"/>
	<variable name="TOTAL_PROFIT" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{PROFIT}]]></variableExpression>
	</variable>
	<variable name="TOTAL_LOSS" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{LOSS}]]></variableExpression>
	</variable>
