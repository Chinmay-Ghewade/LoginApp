<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="ConsolidatedOverdueReport(installment add)" language="groovy" pageWidth="1139" pageHeight="595" orientation="Landscape" columnWidth="1099" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="4e4459d7-f0db-4a3e-b763-009e60cac914">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="branch_code" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="as_on_date" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="report_title" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="user_id" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="product_code" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="from_month" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="to_month" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="to_date" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["./"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT * FROM (
SELECT DISTINCT
    T.ACCOUNT_CODE ACCOUNT_CODE,
    SUBSTR(T.ACCOUNT_CODE, 5, 3) PRODUCT_CODE,
    AA.NAME NAME,
    H.BRANCH_CODE,
    H.NAME BR_NAME,

    (SELECT NAME
     FROM GLOBALCONFIG.CITY
     WHERE CITY_CODE = CC.CITY_CODE) CITY_DESCR,

    (SELECT DESCRIPTION
     FROM HEADOFFICE.PRODUCT
     WHERE PRODUCT_CODE = SUBSTR(T.ACCOUNT_CODE, 5, 3)) PRODUCT_DESCR,

    TO_CHAR(AA.DATEACCOUNTOPEN, 'DD/MM/YYYY') OPEN_D,
    TO_CHAR(TL.ACCOUNTREVIEWDATE, 'DD/MM/YYYY') REVIEW_D,

    TL.SANCTIONAMOUNT SANCTIONAMOUNT,
    TL.INSTALLMENTAMOUNT INSTALLMENTAMOUNT,

    T.LEDGER_BALANCE LEADGER_BALANCE,
    T.OVERDUE_BALANCE OVERDUE_BALANCE,
    T.REC_INT REC_INT,

    FN_GET_OVD_MONTH_NPA(AA.ACCOUNT_CODE, '') OVERDUE_MONTHS,

    (TRIM(CC.ADDRESS1) || ' ' || TRIM(CC.ADDRESS2) || ' ' || TRIM(CC.ADDRESS3)) ADDRESS,

    DECODE(
        (CC.PHONERESIDENCE || '/' || NVL(CC.PHONEMOBILE, 0)),
        '0/0', '0',
        (CC.PHONERESIDENCE || '/' || NVL(CC.PHONEMOBILE, 0))
    ) PHONE_NO

    -- ONLY FOR GUARANTOR REPORT
    , (AG.SERIAL_NUMBER || ' ' || TRIM(AG.NAME)) GUAR_NAME,
      AG.SERIAL_NUMBER

FROM (
    SELECT ACCOUNT_CODE,
           SUM(LEDGER_BALANCE) LEDGER_BALANCE,
           SUM(OVERDUE_BALANCE) OVERDUE_BALANCE,
           SUM(REC_INT) REC_INT,
           LOANRULE_ID
    FROM (
        SELECT
            A.ACCOUNT_CODE,
            LOANRULE_ID,

            FN_GET_BALANCE_ASON('', A.ACCOUNT_CODE) LEDGER_BALANCE,

            OVERDUEONINSTALLMENTRULE(
                A.ACCOUNT_CODE,
               '',
                'N',
                0
            ) OVERDUE_BALANCE,

            (FN_GET_RECPAY_ASON('', A.ACCOUNT_CODE,'N') +
             FN_GET_RECPAY_ASON('', A.ACCOUNT_CODE,'P')) REC_INT

        FROM ACCOUNT.ACCOUNT A,
             HEADOFFICE.PRODUCTPARAMETERLOAN P

        WHERE P.PRODUCT_CODE = SUBSTR(A.ACCOUNT_CODE, 5, 3)

        -- PRODUCT FILTER
        AND P.PRODUCT_CODE = $P{product_code}
        -- LOAN AGAINST FILTER
        AND P.LOANRULE_ID NOT IN (5,3)

        AND P.IS_CAL_OVD = 'Y'
        AND A.DATEACCOUNTOPEN <= $P{as_on_date}
        AND (A.DATEACCOUNTCLOSE IS NULL
             OR A.DATEACCOUNTCLOSE >$P{to_date})

    )
    GROUP BY ACCOUNT_CODE, LOANRULE_ID
    HAVING SUM(LEDGER_BALANCE) <> 0
) T,

HEADOFFICE.BRANCH H,
ACCOUNT.ACCOUNTLOAN TL,
ACCOUNT.ACCOUNT AA,
CUSTOMER.CUSTOMER CC,
ACCOUNT.ACCOUNTGUARANTOR AG

WHERE TL.ACCOUNT_CODE = T.ACCOUNT_CODE
AND T.ACCOUNT_CODE = AA.ACCOUNT_CODE
AND SUBSTR(T.ACCOUNT_CODE,1,4) = H.BRANCH_CODE
AND TL.ACCOUNT_CODE = AG.ACCOUNT_CODE(+)
AND T.OVERDUE_BALANCE > 0

-- DATE CONDITION (Installment/Due Date)
AND TL.ACCOUNTREVIEWDATE >= $P{as_on_date}
AND AA.CUSTOMER_ID = CC.CUSTOMER_ID

ORDER BY T.ACCOUNT_CODE, AG.SERIAL_NUMBER
)

WHERE OVERDUE_MONTHS BETWEEN $P{from_month} AND $P{to_month}
ORDER BY OVERDUE_MONTHS DESC, OVERDUE_BALANCE DESC]]>
	</queryString>
