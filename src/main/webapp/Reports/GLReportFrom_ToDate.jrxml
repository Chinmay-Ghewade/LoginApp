		<defaultValueExpression><![CDATA["./"]]></defaultValueExpression>
	</parameter>
	<parameter name="user_id" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="glaccount_code" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="account_select" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="report_select" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT ROWNUM SERIALNUMBER,
       ACCOUNTCODE,
       ACCOUNTNAME,
       OPENBALANCE,
       TOTALDEBIT,
       TOTALCREDIT,
       OPENBALANCE - TOTALDEBIT + TOTALCREDIT CLOSINGBALANCE
FROM
(
    SELECT op.glaccount_code ACCOUNTCODE,
           gl.description ACCOUNTNAME,
           op.openingbalance OPENBALANCE,

           CASE
               WHEN
     Fn_Get_gl_closing_Sum(
                        $P{branch_code},
                        $P{as_on_date},
                        $P{as_on_date},
                        op.glaccount_code
                    ) < 0
               THEN bet.total_debit -
                    ABS(
                        Fn_Get_gl_closing_Sum(
                           $P{branch_code},
                            $P{as_on_date},
                            $P{as_on_date},
                            op.glaccount_code
                        )
                    )
               ELSE bet.total_debit
           END TOTALDEBIT,

           CASE
               WHEN Fn_Get_gl_closing_Sum(
                       $P{branch_code},
                        $P{as_on_date},
                        $P{as_on_date},
                        op.glaccount_code
                    ) > 0
               THEN bet.total_credit -
                    ABS(
                        Fn_Get_gl_closing_Sum(
                           $P{branch_code},
                            $P{as_on_date},
                            $P{as_on_date},
                            op.glaccount_code
                        )
                    )
               ELSE bet.total_credit
           END TOTALCREDIT,

           (op.openingbalance - bet.total_debit + bet.total_credit) CLOSINGBALANCE

    FROM
        (
            SELECT openingbalance,
                   glaccount_code
            FROM balance.branchglhistory
            WHERE txn_date = $P{as_on_date}
            AND branch_code = $P{branch_code}
        ) op,

        (
            SELECT
                (SUM(debitcash) + SUM(debitclearing) + SUM(debittransfer)) total_debit,
                (SUM(creditcash) + SUM(creditclearing) + SUM(credittransfer)) total_credit,
                glaccount_code
            FROM balance.branchglhistory
            WHERE txn_date BETWEEN
                  $P{as_on_date}
              AND $P{as_on_date}
            AND branch_code = $P{branch_code}

            GROUP BY glaccount_code
        ) bet,

        headoffice.glaccount gl

    WHERE op.glaccount_code = bet.glaccount_code
    AND op.glaccount_code = gl.glaccount_code

    ORDER BY op.glaccount_code
)
WHERE (
        OPENBALANCE <> 0
     OR TOTALDEBIT <> 0
     OR TOTALCREDIT <> 0
     OR (OPENBALANCE - TOTALDEBIT + TOTALCREDIT) <> 0
)]]>
	</queryString>
	<field name="SERIALNUMBER" class="java.math.BigDecimal"/>
	<field name="ACCOUNTCODE" class="java.lang.String"/>
	<field name="ACCOUNTNAME" class="java.lang.String"/>
	<field name="OPENBALANCE" class="java.math.BigDecimal"/>
	<field name="TOTALDEBIT" class="java.math.BigDecimal"/>
	<field name="TOTALCREDIT" class="java.math.BigDecimal"/>
	<field name="CLOSINGBALANCE" class="java.math.BigDecimal"/>
	<variable name="opening_sum" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{OPENBALANCE}]]></variableExpression>
	</variable>
	<variable name="Debit_sum" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{TOTALDEBIT}]]></variableExpression>
	</variable>
	<variable name="Credit_sum" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{TOTALCREDIT}]]></variableExpression>
	</variable>
	<variable name="Closing_sum" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{CLOSINGBALANCE}]]></variableExpression>
	</variable>
