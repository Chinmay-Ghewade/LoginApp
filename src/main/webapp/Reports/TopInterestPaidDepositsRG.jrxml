<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="TopInterestPaidDepositsRG" language="groovy" pageWidth="775" pageHeight="842" columnWidth="735" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="f9737021-99d5-43f9-9969-f8186a0f1acd">
	<property name="ireport.zoom" value="1.5"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="as_on_date" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="from_date" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="to_date" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="branch_code" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="report_title" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="user_id" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="no_of_accounts" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["./"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select ROWNUM SR_NO,account_code,name, ledgerbalance, int_paid FROM
				    ( select * from
				    (SELECT account_code, name,depositamount, int_payable,
				    FN_GET_INT_TD_PAID_PAYBLE_TDS(account_code, $P{from_date}, $P{to_date}, 'I') int_paid,
				    FN_GET_INT_TD_PAID_PAYBLE_TDS(account_code, $P{from_date}, $P{to_date}, 'Y') accured_int,
				    FN_GET_BALANCE_ASON($P{from_date}, account_code) OP_BAL,
				    FN_GET_BALANCE_ASON($P{to_date}, account_code) ASON_BAL,
				    TO_CHAR(DATEACCOUNTCLOSE, 'DD/MM/YYYY') CL_D, 0 AS TDS, ledgerbalance
				    from  (
				    SELECT * from  (
				    SELECT account_code, name, depositamount,interestrate, int_paid,int_payable,
				    nvl(maxdate,'') as maxdate,  nvl(to_date($P{to_date})-maxdate,0) as days, DATEACCOUNTCLOSE, ledgerbalance,
				    case when DATEACCOUNTCLOSE is not null then 0
				    else
				    (CASE WHEN round((depositamount + int_payable)*(to_date($P{to_date})-maxdate)*interestrate/36500) <0 THEN 0
				    ELSE round((depositamount + int_payable)*(to_date($P{to_date})-maxdate)*interestrate/36500) END) end as accured_int
				    from(select trim(a.name) as name,d.account_code,d.depositamount,d.interestrate,a.DATEACCOUNTCLOSE, p.depositrule_id,
				    (SELECT NVL(SUM(INTERESTAMOUNT), 0) AS INTERESTAMOUNT FROM ACCOUNT.ACCOUNTDEPOSITDIARY DD
				    WHERE DD.DEPOSITACCOUNT_CODE = D.ACCOUNT_CODE AND DD.DEPOSITACCOUNT_CODE =  A.ACCOUNT_CODE
				    AND A.ACCOUNT_STATUS = 'C' AND DD.DATEDUE BETWEEN $P{from_date} and $P{to_date}
				    AND DD.APPLIEDFLAG ='N'   AND D.INTERESTPAYMENTFREQUENCY = 'O'   AND D.MATURITYDATE > $P{from_date}
				    AND A.DATEACCOUNTCLOSE BETWEEN $P{from_date} AND $P{to_date}) INT_PAID,
				    (SELECT NVL(SUM(INTERESTAMOUNT), 0) AS INTERESTAMOUNT FROM ACCOUNT.ACCOUNTDEPOSITDIARY DD
				    WHERE DD.DEPOSITACCOUNT_CODE = D.ACCOUNT_CODE  AND DD.DEPOSITACCOUNT_CODE =  A.ACCOUNT_CODE
				    AND A.ACCOUNT_STATUS IN ('L','C','M') AND D.MATURITYDATE > $P{from_date}  AND  A.DATEACCOUNTOPEN <= $P{to_date}
				    AND D.INTERESTPAYMENTFREQUENCY = 'O'  AND (A.DATEACCOUNTCLOSE > $P{to_date} OR A.DATEACCOUNTCLOSE IS NULL)
				    AND DD.DATEDUE BETWEEN $P{from_date} and $P{to_date} AND DD.APPLIEDFLAG ='N' ) INT_PAYABLE,
				    GREATEST(A.DATEACCOUNTOPEN, to_date($P{from_date}),     (SELECT MAX(DATEDUE)
				    FROM ACCOUNT.ACCOUNTDEPOSITDIARY  WHERE DEPOSITACCOUNT_CODE = D.ACCOUNT_CODE
				    AND DATEDUE BETWEEN $P{from_date} and  $P{to_date} AND APPLIEDFLAG ='Y'),
				    (SELECT MAX(DATEDUE) FROM ACCOUNT.ACCOUNTDEPOSITDIARY WHERE DEPOSITACCOUNT_CODE = D.ACCOUNT_CODE
				    AND DATEDUE BETWEEN $P{from_date} and  $P{to_date} AND APPLIEDFLAG ='N')  ) as maxdate, B.LEDGERBALANCE
				    FROM ACCOUNT.ACCOUNT A, ACCOUNT.ACCOUNTDEPOSIT D, HEADOFFICE.PRODUCTPARAMETERDEPOSIT P, BALANCE.ACCOUNT B
				    WHERE A.ACCOUNT_CODE = D.ACCOUNT_CODE  AND SUBSTR(D.ACCOUNT_CODE,5,3) = P.PRODUCT_CODE AND P.IS_TDS_APPLICABLE='Y'
				    AND  A.DATEACCOUNTOPEN <= $P{to_date} AND (A.DATEACCOUNTCLOSE > $P{from_date} OR A.DATEACCOUNTCLOSE IS NULL)
				    AND D.ACCOUNT_CODE = B.ACCOUNT_CODE AND P.DEPOSITRULE_ID = 1)
				    union all
				    (SELECT account_code, name, depositamount,interestrate, int_paid,int_payable,
				    nvl(maxdate,'') as maxdate,   nvl(to_date($P{to_date})-maxdate,0) as days, DATEACCOUNTCLOSE, ledgerbalance,
				    case when DATEACCOUNTCLOSE is not null then 0  else
				    (CASE WHEN round(depositamount*(to_date($P{to_date})-maxdate)*interestrate/36500) <0 THEN 0
				    ELSE round(depositamount*(to_date($P{to_date})-maxdate)*interestrate/36500) END) end as accured_int
				    from (select trim(a.name) as name,d.account_code,d.depositamount,d.interestrate,a.DATEACCOUNTCLOSE ,
				    nvl((CASE WHEN D.INTERESTPAYMENTFREQUENCY IN ('M','Q') THEN
				    (SELECT NVL(SUM(INTERESTAMOUNT), 0) AS INTERESTAMOUNT   FROM ACCOUNT.ACCOUNTDEPOSITDIARY DD,
				    HEADOFFICE.PRODUCTPARAMETERDEPOSIT P  WHERE DD.DEPOSITACCOUNT_CODE = D.ACCOUNT_CODE
				    AND DD.DEPOSITACCOUNT_CODE =  A.ACCOUNT_CODE AND SUBSTR(DD.DEPOSITACCOUNT_CODE,5,3) = P.PRODUCT_CODE  AND P.IS_TDS_APPLICABLE='Y'
				    AND P.DEPOSITRULE_ID <> 1 AND A.ACCOUNT_STATUS = 'C'
				    AND DD.DATEDUE BETWEEN $P{from_date} and $P{to_date}
				    AND A.DATEACCOUNTCLOSE BETWEEN $P{from_date} AND $P{to_date} AND D.MATURITYDATE > $P{from_date} )
				    ELSE ( nvl((SELECT SUM(H.INTERESTAMOUNT) INTERESTAMOUNT     FROM HISTORY.INTERESTPAID H,
				    HEADOFFICE.PRODUCTPARAMETERDEPOSIT P WHERE H.ACCOUNT_CODE = D.ACCOUNT_CODE
				    AND H.ACCOUNT_CODE =  A.ACCOUNT_CODE  AND SUBSTR(H.ACCOUNT_CODE,5,3) = P.PRODUCT_CODE  and P.IS_TDS_APPLICABLE='Y'
				    AND P.DEPOSITRULE_ID <> 1 	 AND A.ACCOUNT_STATUS = 'C'
				    AND H.INTERESTPAID_DATE  >= $P{from_date}     AND H.INTERESTPAID_DATE  <= $P{to_date}
				    AND D.MATURITYDATE > $P{from_date}       AND A.DATEACCOUNTCLOSE BETWEEN $P{from_date} AND $P{to_date}
				    AND D.INTERESTPAYMENTFREQUENCY = 'O'      GROUP BY H.ACCOUNT_CODE ),0) +
				    ( SELECT SUM(DD.NEW_INTERESTPAYABLE) INTERESTAMOUNT FROM HISTORY.INTERESTPAYABLE DD
				    WHERE DD.ACCOUNT_CODE = D.ACCOUNT_CODE AND DD.ACCOUNT_CODE =  A.ACCOUNT_CODE
				    AND SUBSTR(DD.ACCOUNT_CODE,5,3) = P.PRODUCT_CODE AND P.DEPOSITRULE_ID <> 1
				    AND A.ACCOUNT_STATUS = 'C' AND D.MATURITYDATE > $P{from_date}
				    AND A.DATEACCOUNTCLOSE BETWEEN $P{from_date} AND $P{to_date}
				    AND DD.PAYABLE_DATE >= $P{from_date} and DD.PAYABLE_DATE <=$P{to_date}
				    AND D.INTERESTPAYMENTFREQUENCY = 'O'      GROUP BY DD.ACCOUNT_CODE))   END ),0 )INT_PAID,
				    (CASE WHEN D.INTERESTPAYMENTFREQUENCY IN ('M','Q') THEN
				    (SELECT NVL(SUM(INTERESTAMOUNT), 0) AS INTERESTAMOUNT FROM ACCOUNT.ACCOUNTDEPOSITDIARY DD
				    WHERE DD.DEPOSITACCOUNT_CODE = D.ACCOUNT_CODE AND DD.DEPOSITACCOUNT_CODE =  A.ACCOUNT_CODE
				    AND A.ACCOUNT_STATUS IN ('L','M','C')   AND D.MATURITYDATE > $P{from_date}
				    AND DD.DATEDUE BETWEEN $P{from_date} and $P{to_date}
				    AND  A.DATEACCOUNTOPEN <= $P{to_date} AND (A.DATEACCOUNTCLOSE > $P{to_date} OR A.DATEACCOUNTCLOSE IS NULL))
				    ELSE  (SELECT NVL(SUM(NEW_INTERESTPAYABLE), 0) AS INTERESTAMOUNT FROM HISTORY.INTERESTPAYABLE hh
				    WHERE hh.ACCOUNT_CODE = D.ACCOUNT_CODE  AND hh.ACCOUNT_CODE =  A.ACCOUNT_CODE
				    AND A.ACCOUNT_STATUS IN ('L','M','C')   AND D.MATURITYDATE > $P{from_date}
				    AND D.INTERESTPAYMENTFREQUENCY = 'O'
				    AND  A.DATEACCOUNTOPEN <= $P{to_date} AND (A.DATEACCOUNTCLOSE > $P{to_date} OR A.DATEACCOUNTCLOSE IS NULL)
				    AND hh.PAYABLE_DATE BETWEEN $P{from_date} and $P{to_date})END) INT_PAYABLE,
				    GREATEST(A.DATEACCOUNTOPEN, to_date($P{from_date}), (SELECT MAX(DATEDUE) FROM ACCOUNT.ACCOUNTDEPOSITDIARY
				    WHERE DEPOSITACCOUNT_CODE = D.ACCOUNT_CODE  AND DATEDUE BETWEEN $P{from_date} and  $P{to_date}
				    AND APPLIEDFLAG ='Y'), (SELECT MAX(DATEDUE) FROM ACCOUNT.ACCOUNTDEPOSITDIARY WHERE DEPOSITACCOUNT_CODE = D.ACCOUNT_CODE
				    AND DATEDUE BETWEEN $P{from_date} and  $P{to_date} AND APPLIEDFLAG ='N')  ) as maxdate, B.LEDGERBALANCE
				    FROM ACCOUNT.ACCOUNT A, ACCOUNT.ACCOUNTDEPOSIT D, HEADOFFICE.PRODUCTPARAMETERDEPOSIT P, BALANCE.ACCOUNT B
				    WHERE A.ACCOUNT_CODE = D.ACCOUNT_CODE  AND SUBSTR(D.ACCOUNT_CODE,5,3) = P.PRODUCT_CODE AND P.IS_TDS_APPLICABLE='Y'
				    AND  A.DATEACCOUNTOPEN <= $P{to_date} AND (A.DATEACCOUNTCLOSE > $P{from_date} OR A.DATEACCOUNTCLOSE IS NULL)
				    AND D.ACCOUNT_CODE = B.ACCOUNT_CODE AND P.DEPOSITRULE_ID <> 1))
				    ) order by account_code)) where int_paid<>0  order by int_paid desc) where rownum<= $P{no_of_accounts}]]>
	</queryString>
	<field name="SR_NO" class="java.math.BigDecimal"/>
	<field name="ACCOUNT_CODE" class="java.lang.String"/>
	<field name="NAME" class="java.lang.String"/>
	<field name="LEDGERBALANCE" class="java.math.BigDecimal"/>
	<field name="INT_PAID" class="java.math.BigDecimal"/>
	<variable name="TOTAL_LEDGERBALANCE" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{LEDGERBALANCE}]]></variableExpression>
	</variable>
	<variable name="TOTAL_INT_PAID" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{INT_PAID}]]></variableExpression>
	</variable>
