	<queryString>
		<![CDATA[SELECT
    ROW_NUMBER() OVER (ORDER BY TO_NUMBER(p.emp_no)) AS serial,
    p.emp_no,
    '   ' || p.emp_name AS emp_name,
    p.ed_no,
    p.month_year,
    p.amount,
    m.basic_sal
FROM
    payroll.payroll_table p,
    payroll.employee_mst m
WHERE
    p.emp_no = m.emp_no
    AND p.ed_no = $P{ed_no}
    AND p.month_year = $P{month_year}
    AND p.amount <> 0]]>
	</queryString>
	<field name="SERIAL" class="java.math.BigDecimal"/>
	<field name="EMP_NO" class="java.lang.String"/>
	<field name="EMP_NAME" class="java.lang.String"/>
	<field name="ED_NO" class="java.math.BigDecimal"/>
	<field name="MONTH_YEAR" class="java.lang.String"/>
	<field name="AMOUNT" class="java.math.BigDecimal"/>
	<field name="BASIC_SAL" class="java.math.BigDecimal"/>
	<variable name="Amount" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{AMOUNT}]]></variableExpression>
	</variable>
