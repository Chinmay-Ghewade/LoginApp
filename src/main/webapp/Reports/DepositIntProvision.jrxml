	<queryString>
		<![CDATA[SELECT rownum as srno, ACCOUNT_CODE, PRODUCT_CODE, DESCRIPTION, INTERESTPAYBLE, NAME, INTERESTRATE,
              DEPOSITAMOUNT, UNITOFPERIOD, PERIODOFDEPOSIT, B, PROCESSFOR_MATURITY, A, LEDGERBALANCE, MATURITYVALUE
             FROM (
			  SELECT B.ACCOUNT_CODE ,SUBSTR(B.ACCOUNT_CODE,5,3) AS PRODUCT_CODE,K.DESCRIPTION ,B.INTERESTPAYBLE,
			   INITCAP(A.NAME) AS NAME ,B.INTERESTRATE ,B.DEPOSITAMOUNT, B.UNITOFPERIOD, B.PERIODOFDEPOSIT,
			   to_char(B.MATURITYDATE,'DD-MON-YY') AS B, B.PROCESSFOR_MATURITY,to_char(A.DATEACCOUNTOPEN,'DD-MON-YY') AS A ,
			   C.LEDGERBALANCE, B.MATURITYVALUE
              FROM ACCOUNT.ACCOUNTDEPOSIT B,ACCOUNT.ACCOUNT A, BALANCE.ACCOUNT C , HEADOFFICE.PRODUCT K
              WHERE B.ACCOUNT_CODE = A.ACCOUNT_CODE AND B.ACCOUNT_CODE= C.ACCOUNT_CODE AND SUBSTR(B.ACCOUNT_CODE,5,3)= K.PRODUCT_CODE
             AND B.ACCOUNT_CODE LIKE $P{product_code}
               AND A.DATEACCOUNTCLOSE is NULL
               AND B.INTERESTPAYBLE>0
              ORDER BY  B.ACCOUNT_CODE )
             ORDER BY srno]]>
	</queryString>
