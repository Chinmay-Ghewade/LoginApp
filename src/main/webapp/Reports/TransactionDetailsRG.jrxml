	</parameter>
	<parameter name="as_on_date" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="report_title" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="user_id" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["./"]]></defaultValueExpression>
	</parameter>
	<parameter name="to_date" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="indicatorStr" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT D.TXN_DATE,
       D.ACCOUNT_CODE,
       D.TRANSACTIONINDICATOR_CODE,
       D.AMOUNT,
       A.NAME AS ACCOUNT_NAME
FROM transaction.dailytxn D,
     account.account A
WHERE D.user_id = $P{user_id}
  AND D.txn_date BETWEEN $P{as_on_date} AND $P{to_date}
  AND branch_code = $P{branch_code}
  AND D.account_code = A.account_code
AND D.TRANSACTIONINDICATOR_CODE IN ($P!{indicatorStr})]]>
	</queryString>
	<field name="TXN_DATE" class="java.sql.Timestamp"/>
	<field name="ACCOUNT_CODE" class="java.lang.String"/>
	<field name="TRANSACTIONINDICATOR_CODE" class="java.lang.String"/>
	<field name="AMOUNT" class="java.math.BigDecimal"/>
	<field name="ACCOUNT_NAME" class="java.lang.String"/>
