	<parameter name="tocustomerid" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT DISTINCT(C.CUSTOMER_ID) AS CUSTOMER_ID,
       C.NAME NAME,
	   TRIM(C.ADDRESS1)ADDRESS,
	   TRIM(R.DESCRIPTION) CAST,
	   C.PHONEMOBILE

FROM CUSTOMER.CUSTOMER C,
     ACCOUNT.ACCOUNT A,
	 GLOBALCONFIG.RELIGIONCASTE R

WHERE C.CUSTOMER_ID=A.CUSTOMER_ID
    AND C.CASTE_CODE=R.CASTE_CODE
	  AND  C.CUSTOMER_ID between $P{fromcustomerid}
	  and $P{tocustomerid}
	  ORDER BY CUSTOMER_ID]]>
	</queryString>
	<field name="CUSTOMER_ID" class="java.lang.String"/>
	<field name="NAME" class="java.lang.String"/>
	<field name="ADDRESS" class="java.lang.String"/>
	<field name="CAST" class="java.lang.String"/>
	<field name="PHONEMOBILE" class="java.lang.String"/>
