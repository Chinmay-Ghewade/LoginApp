	</parameter>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["./"]]></defaultValueExpression>
	</parameter>
	<parameter name="account_code" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="to_date" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="from_date" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select rownum as sr_no,
       interestpaid_d,
	   interestamount,
	   creditaccount_code
from (
 		select to_char(interestpaid_date,'dd/mm/yyyy') interestpaid_d,
 		interestamount,
		creditaccount_code
    from history.interestpaid

where
 	account_code= $P{account_code}
	and fromdate>= $P{from_date}
 	and todate<= $P{to_date}
	order by interestpaid_date )

order by sr_no]]>
	</queryString>
	<field name="SR_NO" class="java.math.BigDecimal"/>
	<field name="INTERESTPAID_D" class="java.lang.String"/>
	<field name="INTERESTAMOUNT" class="java.math.BigDecimal"/>
	<field name="CREDITACCOUNT_CODE" class="java.lang.String"/>
	<variable name="amount" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{INTERESTAMOUNT}]]></variableExpression>
	</variable>
