	<parameter name="user_id" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
       ROWNUM,
       INTERESTRATE,
       NOOFACCOUNTS,
       BALANCE,
       ROUND((ABS(BALANCE) * INTERESTRATE / 1200), 2) AS INTEREST_AMT
FROM (
        SELECT
               INTERESTRATE,
               COUNT(ACCOUNT_CODE) AS NOOFACCOUNTS,
               SUM(BALANCE) AS BALANCE
        FROM TEMP.LOANCLASS
        WHERE BRANCH_CODE BETWEEN $P{branch_code} AND $P{branch_code}
          AND BALANCE <> 0
        GROUP BY INTERESTRATE
        HAVING INTERESTRATE <> 0
        ORDER BY INTERESTRATE
     )
ORDER BY ROWNUM]]>
	</queryString>
	<field name="ROWNUM" class="java.math.BigDecimal"/>
	<field name="INTERESTRATE" class="java.math.BigDecimal"/>
	<field name="NOOFACCOUNTS" class="java.math.BigDecimal"/>
	<field name="BALANCE" class="java.math.BigDecimal"/>
	<field name="INTEREST_AMT" class="java.math.BigDecimal"/>
	<variable name="NO_OF" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{NOOFACCOUNTS}]]></variableExpression>
	</variable>
	<variable name="OUT_BAL" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{BALANCE}]]></variableExpression>
	</variable>
	<variable name="M_INT" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{INTEREST_AMT}]]></variableExpression>
	</variable>
	<variable name="AVERAGE" class="java.math.BigDecimal" calculation="Average">
		<variableExpression><![CDATA[$F{INTERESTRATE}]]></variableExpression>
	</variable>
