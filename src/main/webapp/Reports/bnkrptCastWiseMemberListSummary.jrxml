	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["D:\\apache-tomcat-8.5.99\\webapps\\ENTERPROJECT\\reports\\"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select ROWNUM SRNO,caste_code,MALE_MEMBERS,FEMALE_MEMBERS,OTHER_MEMBERS,TOTAL_MEMBERS
FROM ( select
MEMBER.CASTE_CODE CASTE_CODE,
SUM(MEMBER.MALE_MEMBERS) MALE_MEMBERS,
SUM(MEMBER.FEMALE_MEMBERS) FEMALE_MEMBERS,
SUM(MEMBER.OTHER_MEMBERS) OTHER_MEMBERS,
SUM(MEMBER.TOTAL_MEMBERS) TOTAL_MEMBERS
 from bankdata.castwisememberlist MEMBER
 where MEMBER.branch_code=$P{branch_code}
 GROUP BY member.caste_code
 order by member.caste_code)]]>
	</queryString>
	<field name="SRNO" class="java.math.BigDecimal"/>
	<field name="CASTE_CODE" class="java.lang.String"/>
	<field name="MALE_MEMBERS" class="java.math.BigDecimal"/>
	<field name="FEMALE_MEMBERS" class="java.math.BigDecimal"/>
	<field name="OTHER_MEMBERS" class="java.math.BigDecimal"/>
	<field name="TOTAL_MEMBERS" class="java.math.BigDecimal"/>
	<variable name="total_male" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{MALE_MEMBERS}]]></variableExpression>
	</variable>
	<variable name="total_female" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{FEMALE_MEMBERS}]]></variableExpression>
	</variable>
	<variable name="total_other" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{OTHER_MEMBERS}]]></variableExpression>
	</variable>
	<variable name="total" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{TOTAL_MEMBERS}]]></variableExpression>
	</variable>
