	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["D:\\apache-tomcat-8.5.99\\webapps\\ENTERPROJECT\\reports\\"]]></defaultValueExpression>
	</parameter>
	<parameter name="to_date" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="from_product" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="to_product" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT rownum srno,D.BRANCH_CODE,A.SHARES_BRANCH,to_number(substr(A.ACCOUNT_CODE,8,7))ACCOUNT_CODE
,A.NAME,D.CURR_BALANCE,D.DIV_AMOUNT,D.CR_ACCOUNT_CODE,
Fn_Get_Account_name(d.cr_account_code) sb_name
FROM ACCOUNT.ACCOUNT A,SHARES.DIVIDEND_CALC D
WHERE D.MEMBER_CODE=A.ACCOUNT_CODE
AND SUBSTR(A.ACCOUNT_CODE,1,4)=0001
AND SUBSTR(A.ACCOUNT_CODE,5,3)=901
AND Y_BEGIN_DATE= $P{as_on_date}
AND Y_END_DATE= $P{to_date}
AND A.SHARES_BRANCH BETWEEN $P{from_product} AND $P{to_product}
ORDER BY A.SHARES_BRANCH,A.ACCOUNT_CODE]]>
	</queryString>
