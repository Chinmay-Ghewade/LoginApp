	<parameter name="member_type" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
    TO_NUMBER(SUBSTR(ACCOUNT_CODE, 8, 14)) AS SHARES_NO,
    NAME,
    FN_GET_MEMBER_ADDRESS(
        SUBSTR(ACCOUNT_CODE, 1, 4),
        'A',
        SUBSTR(ACCOUNT_CODE, 8, 14)
    ) AS ADDRESS,
    TO_CHAR(DATEACCOUNTOPEN, 'DD/MM/YYYY') AS OPEN_D,
    TO_CHAR(DATEACCOUNTCLOSE, 'DD/MM/YYYY') AS CLOSE_D
FROM
    ACCOUNT.ACCOUNT
WHERE
    SUBSTR(ACCOUNT_CODE, 1, 4) = $P{branch_code}
    AND SUBSTR(ACCOUNT_CODE, 5, 3) = (
        SELECT
            MEMBER_PRODUCT
        FROM
            SHARES.MEMBERTYPE_MASTER
        WHERE
            MEMBER_TYPECODE = $P{member_type}
    )
ORDER BY
    ACCOUNT_CODE]]>
	</queryString>
