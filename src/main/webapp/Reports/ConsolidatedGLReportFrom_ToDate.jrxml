<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="ConsolidatedGLReportFrom_ToDate" language="groovy" pageWidth="728" pageHeight="842" columnWidth="688" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="ce1e06fc-d0b5-4b63-aa96-201f4eafa83a">
	<property name="ireport.zoom" value="2.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="branch_code" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="as_on_date" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="report_title" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="user_id" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="to_date" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["./"]]></defaultValueExpression>
	</parameter>
	<parameter name="reportSelect" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
    ROWNUM AS SERIALNUMBER,
    ACCOUNTCODE,
    ACCOUNTNAME,
    OPENBALANCE,
    TOTALDEBIT,
    TOTALCREDIT,
    CLOSINGBALANCE
FROM (
    SELECT
        OP.GLACCOUNT_CODE AS ACCOUNTCODE,
        GL.DESCRIPTION AS ACCOUNTNAME,
        OP.OPENINGBALANCE AS OPENBALANCE,
        BET.TOTAL_DEBIT AS TOTALDEBIT,
        BET.TOTAL_CREDIT AS TOTALCREDIT,
        (OP.OPENINGBALANCE - BET.TOTAL_DEBIT + BET.TOTAL_CREDIT) AS CLOSINGBALANCE
    FROM
        (
            SELECT
                SUM(OPENINGBALANCE) AS OPENINGBALANCE,
                GLACCOUNT_CODE
            FROM
                BALANCE.BRANCHGLHISTORY
            WHERE
                TXN_DATE = $P{as_on_date}
            GROUP BY
                GLACCOUNT_CODE
        ) OP,
        (
            SELECT
                (SUM(DEBITCASH) + SUM(DEBITCLEARING) + SUM(DEBITTRANSFER)) AS TOTAL_DEBIT,
                (SUM(CREDITCASH) + SUM(CREDITCLEARING) + SUM(CREDITTRANSFER)) AS TOTAL_CREDIT,
                GLACCOUNT_CODE
            FROM
                BALANCE.BRANCHGLHISTORY
            WHERE
                TXN_DATE BETWEEN
                    $P{as_on_date}
                    AND $P{to_date}
            GROUP BY
                GLACCOUNT_CODE
        ) BET
        LEFT OUTER JOIN HEADOFFICE.GLACCOUNT GL
            ON BET.GLACCOUNT_CODE = GL.GLACCOUNT_CODE
    WHERE
        OP.GLACCOUNT_CODE = BET.GLACCOUNT_CODE
       AND (
            ($P{reportSelect} = 'L' AND GL.CODETYPE LIKE 'LL%')
            OR ($P{reportSelect} = 'D' AND GL.CODETYPE LIKE 'DD%')
            OR ($P{reportSelect} = 'A' AND (GL.CODETYPE LIKE 'DD%' OR GL.CODETYPE LIKE 'LL%'))
            OR ($P{reportSelect} = 'P' AND GL.ALIE IN ('I', 'E'))
        )
    ORDER BY
        TO_NUMBER(FN_GET_SEQ_NO(OP.GLACCOUNT_CODE))
)]]>
	</queryString>
	<field name="SERIALNUMBER" class="java.math.BigDecimal"/>
	<field name="ACCOUNTCODE" class="java.lang.String"/>
	<field name="ACCOUNTNAME" class="java.lang.String"/>
	<field name="OPENBALANCE" class="java.math.BigDecimal"/>
	<field name="TOTALDEBIT" class="java.math.BigDecimal"/>
	<field name="TOTALCREDIT" class="java.math.BigDecimal"/>
	<field name="CLOSINGBALANCE" class="java.math.BigDecimal"/>
	<variable name="opening_balance" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{OPENBALANCE}]]></variableExpression>
	</variable>
	<variable name="debit_amount" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{TOTALDEBIT}]]></variableExpression>
	</variable>
	<variable name="credit_amount" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{TOTALCREDIT}]]></variableExpression>
	</variable>
	<variable name="closing_balance" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{CLOSINGBALANCE}]]></variableExpression>
	</variable>
